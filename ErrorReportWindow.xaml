<Window x:Class="get_link_manga.ErrorReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERROR REPORT" Height="560" Width="820"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Name="lblErrorTitle"
                       Text="ERROR REPORT"
                       FontSize="18"
                       FontWeight="ExtraBold"
                       Style="{StaticResource CyberpunkHeader}"/>
            <TextBlock Name="lblErrorSubtitle"
                       Foreground="{StaticResource CyberpunkMutedTextBrush}"
                       FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#06090e"
                BorderBrush="{StaticResource CyberpunkBorderBrush}"
                BorderThickness="1"
                CornerRadius="3">
            <DataGrid Name="dgErrors"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      Background="#06090e"
                      RowBackground="#06090e"
                      AlternatingRowBackground="#0c0f17"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1f293d"
                      Foreground="{StaticResource CyberpunkTextBrush}"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      CanUserSortColumns="True"
                      SelectionMode="Extended"
                      PreviewKeyDown="DgErrors_PreviewKeyDown"
                      Sorting="DgErrors_Sorting">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Tích các dòng đang bôi đen (Check Selected)" Click="MenuCheckSelected_Click"/>
                        <MenuItem Header="Bỏ tích các dòng đang bôi đen (Uncheck Selected)" Click="MenuUncheckSelected_Click"/>
                        <MenuItem Header="Đảo ngược trạng thái tích (Invert Checked)" Click="MenuInvertChecked_Click"/>
                        <Separator/>
                        <MenuItem Header="Mở link trong trình duyệt (Open in browser)" Click="MenuOpenInBrowser_Click"/>
                        <Separator/>
                        <MenuItem Header="Sao chép các dòng đang chọn (Copy Selected)" Click="MenuCopySelected_Click"/>
                        <Separator/>
                        <MenuItem Header="Xóa lỗi và truyện khỏi danh sách hiển thị (Delete errors and books)" Click="MenuDeleteErrorsAndBooks_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#121622"/>
                        <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,2"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <!-- Checkbox Column -->
                    <DataGridTemplateColumn Width="38" SortMemberPath="IsChecked">
                        <DataGridTemplateColumn.Header>
                            <Grid HorizontalAlignment="Center">
                                <CheckBox Name="chkSelectAll" Click="ChkSelectAll_Click"/>
                            </Grid>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="⚠" Binding="{Binding Icon}" Width="35" IsReadOnly="True"/>

                    <DataGridTemplateColumn Width="240" SortMemberPath="ComicName">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="COMIC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Path Data="M 0,3 L 3,0 L 6,3 M 0,5 L 3,8 L 6,5" Stroke="{StaticResource CyberpunkCyanBrush}" StrokeThickness="1.2" Width="6" Height="8" Stretch="Fill" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding ComicName}"
                                        Tag="{Binding ComicUrl}"
                                        Click="BtnOpenComicLink_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource CyberpunkCyanBrush}"
                                        FontWeight="Bold"
                                        HorizontalContentAlignment="Left"
                                        Padding="4,2"
                                        Cursor="Hand"
                                        ToolTip="Open comic link"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="130" SortMemberPath="ChapterName">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="CHAPTER" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Path Data="M 0,3 L 3,0 L 6,3 M 0,5 L 3,8 L 6,5" Stroke="{StaticResource CyberpunkCyanBrush}" StrokeThickness="1.2" Width="6" Height="8" Stretch="Fill" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding ChapterName}"
                                        Tag="{Binding ChapterUrl}"
                                        Click="BtnOpenComicLink_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource CyberpunkYellowBrush}"
                                        FontWeight="Bold"
                                        HorizontalContentAlignment="Left"
                                        Padding="4,2"
                                        Cursor="Hand"
                                        ToolTip="Open chapter link"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="65" SortMemberPath="PageNumber">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="PAGE" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Path Data="M 0,3 L 3,0 L 6,3 M 0,5 L 3,8 L 6,5" Stroke="{StaticResource CyberpunkCyanBrush}" StrokeThickness="1.2" Width="6" Height="8" Stretch="Fill" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding PageNumber}"
                                        Tag="{Binding ImageUrl}"
                                        Click="BtnOpenComicLink_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource CyberpunkCyanBrush}"
                                        FontWeight="Bold"
                                        HorizontalContentAlignment="Left"
                                        Padding="4,2"
                                        Cursor="Hand"
                                        ToolTip="Open image link"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="*" SortMemberPath="ErrorMessage">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ERROR" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Path Data="M 0,3 L 3,0 L 6,3 M 0,5 L 3,8 L 6,5" Stroke="{StaticResource CyberpunkCyanBrush}" StrokeThickness="1.2" Width="6" Height="8" Stretch="Fill" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding ErrorMessage}"
                                        Click="BtnClickErrorText_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#ff4444"
                                        HorizontalContentAlignment="Left"
                                        Padding="4,2"
                                        Cursor="Hand"
                                        ToolTip="Locate in main queue">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" 
                                                       Foreground="{TemplateBinding Foreground}" 
                                                       TextWrapping="Wrap" 
                                                       Padding="{TemplateBinding Padding}"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Name="btnRetryFailed"
                    Content="🔄 RETRY FAILED"
                    Click="BtnRetryFailed_Click"
                    Style="{StaticResource CyberpunkButtonPink}"
                    Height="35"
                    Width="140"
                    FontSize="11"/>
            <Button Grid.Column="2"
                    Name="btnCopyErrors"
                    Content="📋 COPY ERRORS"
                    Click="BtnCopyErrors_Click"
                    Style="{StaticResource CyberpunkButtonCyan}"
                    Height="35"
                    Width="140"
                    FontSize="11"/>
            <Button Grid.Column="4"
                    Name="btnClose"
                    Content="CLOSE"
                    Click="BtnClose_Click"
                    Style="{StaticResource CyberpunkButtonCyan}"
                    Height="35"
                    Width="80"
                    FontSize="11"/>
        </Grid>
    </Grid>
</Window>
