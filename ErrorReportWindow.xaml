<Window x:Class="get_link_manga.ErrorReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERROR REPORT" Height="500" Width="650"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Name="lblErrorTitle" Text="ERROR REPORT" 
                       FontSize="18" FontWeight="ExtraBold" 
                       Style="{StaticResource CyberpunkHeader}"/>
            <TextBlock Name="lblErrorSubtitle" 
                       Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                       FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Error List -->
        <Border Grid.Row="1" Background="#06090e" 
                BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                BorderThickness="1" CornerRadius="3">
            <DataGrid Name="dgErrors" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      Background="#06090e"
                      RowBackground="#06090e"
                      AlternatingRowBackground="#0c0f17"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1f293d"
                      Foreground="{StaticResource CyberpunkTextBrush}"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      CanUserSortColumns="True"
                      SelectionMode="Extended">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#121622"/>
                        <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,2"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <!-- Icon -->
                    <DataGridTextColumn Header="⚠️" Binding="{Binding Icon}" Width="35"/>
                    <!-- Chapter -->
                    <DataGridTextColumn Header="CHAPTER" Binding="{Binding ChapterName}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource CyberpunkYellowBrush}"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <!-- Page -->
                    <DataGridTextColumn Header="PAGE" Binding="{Binding PageNumber}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <!-- Error Message -->
                    <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorMessage}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#ff4444"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer Buttons -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Name="btnRetryFailed" Content="🔄 RETRY FAILED" 
                    Click="BtnRetryFailed_Click"
                    Style="{StaticResource CyberpunkButtonPink}" 
                    Height="35" Width="140" FontSize="11"/>
            <Button Grid.Column="2" Name="btnCopyErrors" Content="📋 COPY ERRORS" 
                    Click="BtnCopyErrors_Click"
                    Style="{StaticResource CyberpunkButtonCyan}" 
                    Height="35" Width="140" FontSize="11"/>
            <Button Grid.Column="4" Name="btnClose" Content="CLOSE" 
                    Click="BtnClose_Click"
                    Style="{StaticResource CyberpunkButtonCyan}" 
                    Height="35" Width="80" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
