<Window x:Class="get_link_manga.BookmarkHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DOWNLOAD &amp; COMIC BOOKMARKS" Height="600" Width="550"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📑 DOWNLOAD &amp; COMIC BOOKMARKS" 
                   FontSize="18" FontWeight="ExtraBold" 
                   Style="{StaticResource CyberpunkHeader}"
                   Margin="0,0,0,15"/>

        <!-- Tab Control -->
        <TabControl Name="tabMenu" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#121622"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkMutedTextBrush}"/>
                    <Setter Property="Padding" Value="15,8"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="tabBorder" Background="#121622" 
                                        BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                        BorderThickness="1,1,1,0" 
                                        CornerRadius="4,4,0,0" 
                                        Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                                    <ContentPresenter ContentSource="Header" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#1a1f30"/>
                                        <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#1c1122"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- History Tab -->
            <TabItem Header="📜 History">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#06090e" 
                            BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                            BorderThickness="1" CornerRadius="3">
                        <ListBox Name="lstHistory" 
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0c0f17" 
                                            BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                            BorderThickness="0,0,0,1" 
                                            Padding="10,8" Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding DownloadedAt, StringFormat='{}{0:HH:mm dd-MM-yyyy}'}" 
                                                           Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                                           FontSize="10"/>
                                                <TextBlock Text="{Binding SourceDomain}" 
                                                           Foreground="{StaticResource CyberpunkCyanBrush}" 
                                                           FontSize="10" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="{StaticResource CyberpunkTextBrush}" 
                                                           FontWeight="Bold" FontSize="13" 
                                                           TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                <TextBlock Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                                           FontSize="10" Margin="0,2,0,0">
                                                    <Run Text="Chapters: "/>
                                                    <Run Text="{Binding ChaptersDownloaded, Mode=OneWay}" Foreground="{StaticResource CyberpunkYellowBrush}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Open Link Button -->
                                            <Button Grid.Column="1" Content="🌐" 
                                                    Tag="{Binding Url}"
                                                    Click="BtnOpenHistoryLink_Click"
                                                    Width="32" Height="32" Margin="6,0"
                                                    Style="{StaticResource CyberpunkButtonCyan}"
                                                    FontSize="14" Padding="0"
                                                    ToolTip="Mở link trong trình duyệt"/>
                                            <!-- Open Folder Button -->
                                            <Button Grid.Column="2" Content="📁" 
                                                    Tag="{Binding DownloadPath}"
                                                    Click="BtnOpenHistoryFolder_Click"
                                                    Width="32" Height="32"
                                                    Style="{StaticResource CyberpunkButtonCyan}"
                                                    FontSize="14" Padding="0"
                                                    ToolTip="Mở thư mục tải"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Name="lblHistoryCount" Grid.Column="0"
                                   Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                   FontSize="11" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="💾 SAVE" 
                                Click="BtnSaveHistory_Click"
                                Style="{StaticResource CyberpunkButtonCyan}" 
                                Height="30" Width="70" FontSize="11"/>
                        <Button Grid.Column="3" Content="📂 LOAD" 
                                Click="BtnLoadHistory_Click"
                                Style="{StaticResource CyberpunkButtonCyan}" 
                                Height="30" Width="70" FontSize="11"/>
                        <Button Grid.Column="5" Content="🗑️ CLEAR" 
                                Click="BtnClearHistory_Click"
                                Style="{StaticResource CyberpunkButtonPink}" 
                                Height="30" Width="90" FontSize="11"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Bookmarks Tab -->
            <TabItem Header="📌 Download bookmarks">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#06090e" 
                            BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                            BorderThickness="1" CornerRadius="3">
                        <ListBox Name="lstBookmarks" 
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MouseDoubleClick="LstBookmarks_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0c0f17" 
                                            BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                            BorderThickness="0,0,0,1" 
                                            Padding="10,8" Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding BookmarkedAt, StringFormat='{}{0:HH:mm dd-MM-yyyy}'}" 
                                                           Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                                           FontSize="10"/>
                                                <TextBlock Text="{Binding SourceDomain}" 
                                                           Foreground="{StaticResource CyberpunkCyanBrush}" 
                                                           FontSize="10" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Name}" 
                                                           Foreground="{StaticResource CyberpunkYellowBrush}" 
                                                           FontWeight="Bold" FontSize="13" 
                                                           TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <!-- Open Link Button -->
                                            <Button Grid.Column="1" Content="🌐" 
                                                    Tag="{Binding Url}"
                                                    Click="BtnOpenBookmarkLink_Click"
                                                    Width="32" Height="32" Margin="6,0"
                                                    Style="{StaticResource CyberpunkButtonCyan}"
                                                    FontSize="14" Padding="0"
                                                    ToolTip="Mở link trong trình duyệt"/>
                                            <!-- Delete Button -->
                                            <Button Grid.Column="2" Content="🗑️" 
                                                    Tag="{Binding Url}"
                                                    Click="BtnDeleteBookmark_Click"
                                                    Width="32" Height="32"
                                                    Style="{StaticResource CyberpunkButtonPink}"
                                                    FontSize="14" Padding="0"
                                                    ToolTip="Xóa bookmark"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Name="lblBookmarkCount" Grid.Column="0"
                                   Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                   FontSize="11" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="💾 SAVE" 
                                Click="BtnSaveBookmarks_Click"
                                Style="{StaticResource CyberpunkButtonCyan}" 
                                Height="30" Width="70" FontSize="11"/>
                        <Button Grid.Column="3" Content="📂 LOAD" 
                                Click="BtnLoadBookmarks_Click"
                                Style="{StaticResource CyberpunkButtonCyan}" 
                                Height="30" Width="70" FontSize="11"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="📍 Comic bookmarks">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#06090e"
                            BorderBrush="{StaticResource CyberpunkBorderBrush}"
                            BorderThickness="1" CornerRadius="3">
                        <ListBox Name="lstReaderPageBookmarks"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MouseDoubleClick="LstReaderPageBookmarks_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0c0f17"
                                            BorderBrush="{StaticResource CyberpunkBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="10,8" Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding BookmarkedAt, StringFormat='{}{0:HH:mm dd-MM-yyyy}'}"
                                                           Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                                           FontSize="10"/>
                                                <TextBlock Text="{Binding MangaName}"
                                                           Foreground="{StaticResource CyberpunkYellowBrush}"
                                                           FontWeight="Bold" FontSize="13"
                                                           TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding ChapterName}"
                                                           Foreground="{StaticResource CyberpunkCyanBrush}"
                                                           FontSize="10" Margin="0,2,0,0"/>
                                                <TextBlock Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                                           FontSize="10" Margin="0,2,0,0">
                                                    <Run Text="Page: "/>
                                                    <Run Text="{Binding PageIndex, Mode=OneWay}" Foreground="{StaticResource CyberpunkYellowBrush}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding PageName, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="1" Content="📖"
                                                    Click="BtnOpenReaderPageBookmark_Click"
                                                    Width="32" Height="32" Margin="6,0"
                                                    Style="{StaticResource CyberpunkButtonCyan}"
                                                    FontSize="14" Padding="0"
                                                    ToolTip="Mở bookmark trang"/>

                                            <Button Grid.Column="2" Content="🗑️"
                                                    Tag="{Binding BookmarkId}"
                                                    Click="BtnDeleteReaderPageBookmark_Click"
                                                    Width="32" Height="32"
                                                    Style="{StaticResource CyberpunkButtonPink}"
                                                    FontSize="14" Padding="0"
                                                    ToolTip="Xóa bookmark trang"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Name="lblReaderPageBookmarkCount" Grid.Column="0"
                                   Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                   FontSize="11" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="🗑️ CLEAR"
                                Click="BtnClearReaderPageBookmarks_Click"
                                Style="{StaticResource CyberpunkButtonPink}"
                                Height="30" Width="90" FontSize="11"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
