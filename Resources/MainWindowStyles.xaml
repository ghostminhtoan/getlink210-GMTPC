        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="ScaleResetButton" TargetType="Button" BasedOn="{StaticResource CompactPinkButton}">
        <Setter Property="Height" Value="28"/>
        <Setter Property="MinWidth" Value="62"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="ScaleSlider" TargetType="Slider">
        <Setter Property="Minimum" Value="80"/>
        <Setter Property="Maximum" Value="140"/>
        <Setter Property="TickFrequency" Value="5"/>
        <Setter Property="Height" Value="20"/>
    </Style>

    <Style x:Key="WorkspaceSectionCard" TargetType="Border">
        <Setter Property="Background" Value="#0D121F"/>
        <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="ShutdownPopupButton" TargetType="Button" BasedOn="{StaticResource CyberpunkButtonPink}">
        <Setter Property="Height" Value="26"/>
        <Setter Property="MinWidth" Value="42"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="ToolTip" Value="Shutdown options"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF007F" BlurRadius="18" ShadowDepth="0" Opacity="0.30"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ShutdownActionToggleButton" TargetType="ToggleButton">
        <Setter Property="Height" Value="34"/>
        <Setter Property="MinWidth" Value="228"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="#FFF5C9"/>
        <Setter Property="Background" Value="#3A1821"/>
        <Setter Property="BorderBrush" Value="#FF5D8F"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF007F" BlurRadius="18" ShadowDepth="0" Opacity="0.30"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="shutdownBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="shutdownBorder" Property="Background" Value="#54202F"/>
                            <Setter TargetName="shutdownBorder" Property="BorderBrush" Value="#FF82AB"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="#100A00"/>
                            <Setter TargetName="shutdownBorder" Property="Background" Value="{StaticResource CyberpunkYellowBrush}"/>
                            <Setter TargetName="shutdownBorder" Property="BorderBrush" Value="#FFF8A6"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.60"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ShutdownPopupCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="ShutdownTimeTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#0B1726"/>
        <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource CyberpunkCyanBrush}"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="ShutdownPopupBorder" TargetType="Border">
        <Setter Property="Background" Value="#101C2D"/>
        <Setter Property="BorderBrush" Value="#FF5D8F"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#02060D" BlurRadius="24" ShadowDepth="0" Opacity="0.45"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ShutdownPopupLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CyberpunkMutedTextBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="ShutdownPopupValueSeparator" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="5,0"/>
    </Style>

    <Style x:Key="ShutdownPopupHint" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CyberpunkYellowBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Margin" Value="0,10,0,10"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ShutdownPopupMiniButton" TargetType="Button" BasedOn="{StaticResource CompactCyanButton}">
        <Setter Property="Width" Value="86"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="ShutdownPopupMiniDangerButton" TargetType="Button" BasedOn="{StaticResource CompactPinkButton}">
        <Setter Property="Width" Value="86"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="ShutdownPopupHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="FloatToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Width" Value="70"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="BackgroundBorder"
                            CornerRadius="12"
                            Background="#D8212A"
                            BorderBrush="#F4626B"
                            BorderThickness="1.3"
                            Padding="3"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock x:Name="StateText"
                                       Text="OFF"
                                       FontWeight="Bold"
                                       FontSize="10"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextDecorations="Underline"/>
                            
                            <Border x:Name="Thumb"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="8"
                                    Background="#DFE5FA"
                                    BorderBrush="#C6CFF1"
                                    BorderThickness="1.1"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#58D600"/>
                            <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="#7FE627"/>
                            <Setter TargetName="StateText" Property="Text" Value="ON"/>
                            <Setter TargetName="StateText" Property="Grid.Column" Value="0"/>
                            <Setter TargetName="Thumb" Property="Grid.Column" Value="1"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#D8212A"/>
                            <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="#F4626B"/>
                            <Setter TargetName="StateText" Property="Text" Value="OFF"/>
                            <Setter TargetName="StateText" Property="Grid.Column" Value="1"/>
                            <Setter TargetName="Thumb" Property="Grid.Column" Value="0"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Left"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
