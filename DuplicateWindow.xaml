<Window x:Class="get_link_manga.DuplicateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:get_link_manga"
        mc:Ignorable="d"
        Title="DUPLICATE NAME MANAGER" Height="600" Width="850"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- DataGrid Style -->
        <Style x:Key="CyberpunkDataGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="#06090e"/>
            <Setter Property="RowBackground" Value="#06090e"/>
            <Setter Property="AlternatingRowBackground" Value="#0c0f17"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1f293d"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1f293d"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <!-- Column Header Style -->
        <Style x:Key="CyberpunkDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#121622"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1c1122"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row Style -->
        <Style x:Key="CyberpunkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#161f30"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e2d4a"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell Style -->
        <Style x:Key="CyberpunkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- DataGrid -->
            <RowDefinition Height="*"/>
            <!-- Footer -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CyberpunkPinkBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="POTENTIAL DUPLICATE REVIEW // FINDER SYSTEM" 
                               FontSize="18" 
                               FontWeight="ExtraBold" 
                               Style="{StaticResource CyberpunkHeader}"/>
                    <TextBlock Text="REVIEWS HIGH PROBABILITY DUPLICATES AND BOOK VARIATIONS (PART/CHAP/COLOR/CEN)" 
                               FontSize="9" 
                               Foreground="{StaticResource CyberpunkCyanBrush}" 
                               FontWeight="Bold"
                               Margin="2,2,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#1c1122" BorderBrush="{StaticResource CyberpunkPinkBrush}" BorderThickness="1" CornerRadius="3" Padding="10,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Duplicate Items: " Foreground="{StaticResource CyberpunkTextBrush}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Name="lblDupCount" Text="0" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="txtFilter" 
                        TextChanged="TxtFilter_TextChanged"
                        Background="#0e121a" 
                        BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                        Foreground="{StaticResource CyberpunkTextBrush}" 
                        CaretBrush="{StaticResource CyberpunkCyanBrush}"
                        Height="30"
                        VerticalContentAlignment="Center"/>

            <Button Grid.Column="2" Name="btnCheckAll" Content="CHECK ALL" Click="BtnCheckAll_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="100" FontSize="11"/>
            <Button Grid.Column="4" Name="btnUncheckAll" Content="UNCHECK ALL" Click="BtnUncheckAll_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="100" FontSize="11"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" 
                  Name="dgDuplicates"
                  Style="{StaticResource CyberpunkDataGrid}"
                  ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                  RowStyle="{StaticResource CyberpunkDataGridRow}"
                  CellStyle="{StaticResource CyberpunkDataGridCell}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  PreviewKeyDown="DgDuplicates_PreviewKeyDown"
                  PreviewTextInput="DgDuplicates_PreviewTextInput"
                  MouseDoubleClick="DgDuplicates_MouseDoubleClick"
                  Margin="0,0,0,15">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Tích chọn dòng đang bôi đen (Check Selected)" Click="MenuCheckSelected_Click"/>
                    <MenuItem Header="Bỏ tích dòng đang bôi đen (Uncheck Selected)" Click="MenuUncheckSelected_Click"/>
                    <MenuItem Header="Đảo ngược trạng thái tích (Invert Checked)" Click="MenuInvertChecked_Click"/>
                    <Separator/>
                    <MenuItem Header="Copy link các dòng đang chọn (Copy Selected Links)" Click="MenuCopySelectedLinks_Click"/>
                    <Separator/>
                    <MenuItem Header="Xóa các dòng đang bôi đen (Delete Selected)" Click="MenuDeleteSelected_Click"/>
                    <MenuItem Header="Xóa các dòng đã tích (Delete Checked)" Click="MenuDeleteChecked_Click"/>
                    <Separator/>
                    <MenuItem Header="Tải các dòng đang bôi đen (Download highlighted lines)" Click="MenuDownloadSelected_Click"/>
                    <MenuItem Header="Tải các dòng đã tích (Download selected lines)" Click="MenuDownloadChecked_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <!-- Checkbox Column -->
                <DataGridTemplateColumn Width="45">
                    <DataGridTemplateColumn.Header>
                        <Grid HorizontalAlignment="Center">
                            <CheckBox Name="chkSelectAll" Click="ChkSelectAll_Click"/>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Gallery Details Column (Cyan colored title and cyan colored link) -->
                <DataGridTemplateColumn Header="DUPLICATE DETAILS" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5,4" Orientation="Vertical">
                                <!-- Title -->
                                <TextBlock Text="{Binding Name}" 
                                           Foreground="{StaticResource CyberpunkCyanBrush}" 
                                           FontWeight="Bold" 
                                           FontSize="12"
                                           Margin="0,0,0,4"
                                           TextWrapping="NoWrap"/>
                                <!-- Link -->
                                <TextBlock Text="{Binding Link}" 
                                           Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                           FontSize="11"
                                           TextWrapping="NoWrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Quick Status message -->
            <TextBlock Name="lblStatus" Text="Ready to analyze." Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>

            <Button Grid.Column="1" Name="btnClose" Content="CLOSE CONTROL" Click="BtnClose_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35" Width="140" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>
