<Application x:Class="get_link_manga.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:get_link_manga">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Cyberpunk Color Palette -->
            <Color x:Key="CyberpunkDarkColor">#0a0d14</Color>
            <Color x:Key="CyberpunkCardColor">#121622</Color>
            <Color x:Key="CyberpunkCyanColor">#00f0ff</Color>
            <Color x:Key="CyberpunkPinkColor">#ff00ea</Color>
            <Color x:Key="CyberpunkYellowColor">#ffe600</Color>
            <Color x:Key="CyberpunkBorderColor">#1f293d</Color>

            <SolidColorBrush x:Key="CyberpunkDarkBrush" Color="{StaticResource CyberpunkDarkColor}" />
            <SolidColorBrush x:Key="CyberpunkCardBrush" Color="{StaticResource CyberpunkCardColor}" />
            <SolidColorBrush x:Key="CyberpunkCyanBrush" Color="{StaticResource CyberpunkCyanColor}" />
            <SolidColorBrush x:Key="CyberpunkPinkBrush" Color="{StaticResource CyberpunkPinkColor}" />
            <SolidColorBrush x:Key="CyberpunkYellowBrush" Color="{StaticResource CyberpunkYellowColor}" />
            <SolidColorBrush x:Key="CyberpunkBorderBrush" Color="{StaticResource CyberpunkBorderColor}" />
            <SolidColorBrush x:Key="CyberpunkTextBrush" Color="#ffffff" />
            <SolidColorBrush x:Key="CyberpunkMutedTextBrush" Color="#7a8d9e" />

            <!-- Custom Cyberpunk Card Style -->
            <Style x:Key="CyberpunkCard" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CyberpunkCardBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource CyberpunkCyanBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Cyberpunk Glow Effect -->
            <DropShadowEffect x:Key="CyberpunkCyanGlow" Color="{StaticResource CyberpunkCyanColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.75" />
            <DropShadowEffect x:Key="CyberpunkPinkGlow" Color="{StaticResource CyberpunkPinkColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.75" />
            
            <!-- Cyberpunk Button Base Template -->
             <ControlTemplate x:Key="CyberpunkButtonTemplate" TargetType="Button">
                <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="2"
                        SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}">
                        <ContentPresenter.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </ContentPresenter.Resources>
                    </ContentPresenter>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Cyberpunk Button Customizations -->
            <Style x:Key="CyberpunkButtonCyan" TargetType="Button">
                <Setter Property="Template" Value="{StaticResource CyberpunkButtonTemplate}"/>
                <Setter Property="Background" Value="#121622"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberpunkCyanBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="10,4"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource CyberpunkCyanBrush}"/>
                        <Setter Property="Foreground" Value="#0a0d14"/>
                        <Setter Property="Effect" Value="{StaticResource CyberpunkCyanGlow}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.85"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CyberpunkButtonPink" TargetType="Button">
                <Setter Property="Template" Value="{StaticResource CyberpunkButtonTemplate}"/>
                <Setter Property="Background" Value="#121622"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberpunkPinkBrush}"/>
                <Setter Property="Foreground" Value="#ffffff"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="10,4"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource CyberpunkPinkBrush}"/>
                        <Setter Property="Foreground" Value="#0a0d14"/>
                        <Setter Property="Effect" Value="{StaticResource CyberpunkPinkGlow}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.85"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CyberpunkButtonImportant" TargetType="Button">
                <Setter Property="Template" Value="{StaticResource CyberpunkButtonTemplate}"/>
                <Setter Property="Background" Value="#18170c"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberpunkYellowBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyberpunkYellowBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="12,6"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource CyberpunkYellowBrush}"/>
                        <Setter Property="Foreground" Value="#0a0d14"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="{StaticResource CyberpunkYellowColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.85"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CyberpunkHeader" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI, Impact, Arial"/>
                <Setter Property="FontWeight" Value="UltraBold"/>
                <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
                <Setter Property="Effect" Value="{StaticResource CyberpunkPinkGlow}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
