            <!-- Right Output Panel (Shared) -->
            <Border Name="borderRightPanel" Grid.Column="2" Grid.Row="0" Style="{StaticResource CyberpunkCard}" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Filter & Sort Toolbar -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                        <RowDefinition Height="Auto"/> <!-- Download Section -->
                    </Grid.RowDefinitions>

                    <!-- Action Buttons Toolbar -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,12" Orientation="Horizontal">
                        <Button Content="COPY LINKS" Click="BtnCopyLinksOnly_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Width="130" Margin="0,0,8,8" FontWeight="Bold"/>
                        <Button Content="COPY NAME+LINK" Click="BtnCopyNamesAndLinks_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35" Width="160" Margin="0,0,8,8" FontWeight="Bold"/>
                        <Button Content="SAVE LIST" Click="BtnSave_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Width="130" Margin="0,0,8,8" FontWeight="Bold"/>
                        <Button Content="LOAD LIST" Click="BtnLoad_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35" Width="130" Margin="0,0,8,8" FontWeight="Bold"/>
                        <Button Content="CLEAR" Click="BtnClear_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Width="80" Margin="0,0,8,8" FontWeight="Bold"/>
                    </WrapPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="EXTRACTED GALLERY LINKS" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>

                        <!-- Word Wrap Switch -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="WORD WRAP" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ToggleButton Name="chkWordWrap" Style="{StaticResource ToggleButtonSwitch}" Height="20" Width="40"/>
                        </StackPanel>

                        <Border Grid.Column="3" Background="#1c1122" BorderBrush="{StaticResource CyberpunkPinkBrush}" BorderThickness="1" CornerRadius="3" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total Books: " Foreground="{StaticResource CyberpunkTextBrush}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Name="lblLinkCount" Text="0" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Toolbar for Filtering and Sorting -->
                    <WrapPanel Grid.Row="2" Margin="0,0,0,20" Orientation="Horizontal">
                        <Button Name="btnSortByName" Content="SORT BY NAME" Click="BtnSortByName_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="120" FontSize="11" Margin="0,0,8,8"/>
                        <Button Name="btnRestoreOrder" Content="RESTORE ORDER" Click="BtnRestoreOrder_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="120" FontSize="11" Margin="0,0,8,8"/>
                        <Button Name="btnDuplicateName" Content="DUPLICATE NAME" Click="BtnDuplicateName_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="120" FontSize="11" Margin="0,0,8,8"/>
                        <Button Name="btnNoLinkViHentai" Content="NO LINK (VI-HENTAI)" Click="BtnNoLinkViHentai_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="150" FontSize="11" Margin="0,0,8,8"/>
                        <Button Name="btnReverseOrder" Content="REVERSE ORDER" Click="BtnReverseOrder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="150" FontSize="11" Margin="0,0,8,8"/>
                        <Button Name="btnClearComplete" Content="CLEAR COMPLETE BOOKS" Click="BtnClearComplete_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="180" FontSize="11" Margin="0,0,8,8"/>
                    </WrapPanel>

                    <!-- Scraped links DataGrid -->
                    <DataGrid Grid.Row="3" 
                              Name="dgResults"
                              Style="{StaticResource CyberpunkDataGrid}"
                              ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                              RowStyle="{StaticResource CyberpunkDataGridRow}"
                              CellStyle="{StaticResource CyberpunkDataGridCell}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              PreviewKeyDown="DgResults_PreviewKeyDown"
                              PreviewTextInput="DgResults_PreviewTextInput"
                              PreviewMouseLeftButtonDown="DgResults_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.ScrollUnit="Item"
                              EnableRowVirtualization="True"
                              Margin="0,10,0,15">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Tích chọn dòng đang bôi đen (Check Selected)" Click="MenuCheckSelected_Click"/>
                                <MenuItem Header="Bỏ tích dòng đang bôi đen (Uncheck Selected)" Click="MenuUncheckSelected_Click"/>
                                <MenuItem Header="Đảo ngược trạng thái tích (Invert Checked)" Click="MenuInvertChecked_Click"/>
                                <Separator/>
                                <MenuItem Header="📌 Bookmark dòng đang chọn" Click="MenuBookmarkSelected_Click"/>
                                <MenuItem Header="🌐 Mở link trong trình duyệt" Click="MenuOpenInBrowser_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy link các dòng đang chọn (Copy Selected Links)" Click="MenuCopySelectedLinks_Click"/>
                                <Separator/>
                                <MenuItem Header="Xóa các dòng đang bôi đen (Delete Selected)" Click="MenuDeleteSelected_Click"/>
                                <MenuItem Header="Xóa các dòng đã tích (Delete Checked)" Click="MenuDeleteChecked_Click"/>
                                <Separator/>
                                <MenuItem Header="Tải các dòng đang bôi đen (Download highlighted lines)" Click="MenuDownloadSelected_Click"/>
                                <MenuItem Header="Tải các dòng đã tích (Download selected lines)" Click="MenuDownloadChecked_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <!-- Checkbox Column -->
                            <DataGridTemplateColumn Width="45">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Center">
                                        <CheckBox Name="chkSelectAll" Click="ChkSelectAll_Click"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Gallery Details Column (Vertical stack of Name and Link) -->
                            <DataGridTemplateColumn Header="GALLERY DETAILS (TITLE &amp; URL)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5,4" Orientation="Vertical">
                                            <!-- Title -->
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="Bold" 
                                                       FontSize="12"
                                                       Margin="0,0,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CyberpunkYellowBrush}"/>
                                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=chkWordWrap}" Value="True">
                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasNoChapters}" Value="True">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Link -->
                                            <TextBlock Text="{Binding Link}" 
                                                       Foreground="{StaticResource CyberpunkCyanBrush}" 
                                                       FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=chkWordWrap}" Value="True">
                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Chapter Count -->
                                            <TextBlock Text="{Binding LinkCount, StringFormat=latest chap: {0}}" 
                                                       Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                                       FontSize="10"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                             <!-- Status Column -->
                             <DataGridTemplateColumn Header="STATUS" Width="180">
                                 <DataGridTemplateColumn.CellTemplate>
                                     <DataTemplate>
                                         <Grid Margin="5,4">
                                             <Grid.Style>
                                                 <Style TargetType="Grid">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding Status}" Value="{x:Null}">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                         <DataTrigger Binding="{Binding Status}" Value="">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </Grid.Style>
                                             <Grid.RowDefinitions>
                                                 <RowDefinition Height="Auto"/>
                                                 <RowDefinition Height="Auto"/>
                                             </Grid.RowDefinitions>

                                             <!-- Row 0: Status Text, Action Buttons and Error Button -->
                                             <Grid Grid.Row="0" Margin="0,0,0,4">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                 </Grid.ColumnDefinitions>

                                                 <!-- Status Display -->
                                                 <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Background="Transparent">
                                                     <TextBlock FontSize="11" FontWeight="Bold" Foreground="{StaticResource CyberpunkCyanBrush}">
                                                         <TextBlock.Style>
                                                             <Style TargetType="TextBlock">
                                                                 <Setter Property="Text" Value="⏳ Waiting"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                         <Setter Property="Text" Value="⬇️ Loading"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                         <Setter Property="Text" Value="✅ Done"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                         <Setter Property="Text" Value="❌ Error"/>
                                                                         <Setter Property="Foreground" Value="Red"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                         <Setter Property="Text" Value="⏸️ Paused"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </TextBlock.Style>
                                                     </TextBlock>
                                                 </StackPanel>

                                                 <!-- Row Buttons -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                                                    <!-- Stop Button -->
                                                    <Button Content="⏹️" Click="BtnRowStop_Click" Width="22" Height="18" Margin="1,0" Padding="0" FontSize="8" ToolTip="Stop download">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonPink}">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Queued">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                 </StackPanel>

                                                 <!-- Error Button -->
                                                 <Button Grid.Column="2" Content="{Binding ErrorCount, StringFormat=Err: {0}}" 
                                                         Click="BtnShowErrors_Click"
                                                         VerticalAlignment="Center"
                                                         Margin="4,0,0,0" Height="18" Padding="3,0" FontSize="9">
                                                     <Button.Style>
                                                         <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                             <Setter Property="Visibility" Value="Visible"/>
                                                             <Setter Property="Background" Value="#ff2222"/>
                                                             <Setter Property="BorderBrush" Value="#ff4444"/>
                                                             <Setter Property="Foreground" Value="White"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding ErrorCount}" Value="0">
                                                                     <Setter Property="Visibility" Value="Collapsed"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Button.Style>
                                                 </Button>
                                             </Grid>

                                             <!-- Row 1: Progress Bar with Text Overlay -->
                                             <Grid Grid.Row="1" Height="14" Margin="0,2,0,0">
                                                 <Grid.Style>
                                                     <Style TargetType="Grid">
                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                             <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Grid.Style>

                                                 <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100" Foreground="{StaticResource CyberpunkCyanBrush}" Style="{StaticResource ProgressBarSuccess}" Height="14" VerticalAlignment="Center"/>
                                                 
                                                 <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}" 
                                                            Foreground="Red" 
                                                            FontSize="9" 
                                                            FontWeight="Bold"
                                                            HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                             </Grid>
                                         </Grid>
                                     </DataTemplate>
                                 </DataGridTemplateColumn.CellTemplate>
                             </DataGridTemplateColumn>

                             <!-- Process Column -->
                             <DataGridTemplateColumn Header="PROCESS" Width="200">
                                  <DataGridTemplateColumn.CellTemplate>
                                      <DataTemplate>
                                          <StackPanel Margin="5,4" Orientation="Vertical" Background="Transparent">
                                             <StackPanel.Style>
                                                 <Style TargetType="StackPanel">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding Status}" Value="{x:Null}">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                         <DataTrigger Binding="{Binding Status}" Value="">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </StackPanel.Style>

                                             <!-- Row 1: Downloading Chapter -->
                                             <TextBlock Text="{Binding DownloadingChapter}" 
                                                        Foreground="{StaticResource CyberpunkYellowBrush}" 
                                                        FontSize="11" 
                                                        FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis"/>

                                             <!-- Row 2: Page Progress -->
                                             <TextBlock Text="{Binding DownloadingPageProgress}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        FontSize="10" 
                                                        Margin="0,2,0,0"/>
                                         </StackPanel>
                                     </DataTemplate>
                                 </DataGridTemplateColumn.CellTemplate>
                             </DataGridTemplateColumn>

                            <!-- Action Buttons Column -->
                            <DataGridTemplateColumn Header="VIEW LINK" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="🌐" 
                                                    Tag="{Binding Link}" 
                                                    Click="BtnOpenLinkInRow_Click"
                                                    Width="30" Height="28" Margin="2,0"
                                                    Style="{StaticResource CyberpunkButtonCyan}"
                                                    FontSize="13" Padding="0"
                                                    ToolTip="Mở link trong trình duyệt"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Download Section -->
                    <Border Grid.Row="4" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Path Config -->
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/> <!-- Folder Actions (Merge/Split) -->
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/> <!-- Chapter Selection -->
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/> <!-- Connections and Start Download -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: Path Config -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "DOWNLOAD PATH" Label -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>    <!-- Textbox for folder path -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- BROWSE button -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- OPEN FOLDER button -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="DOWNLOAD PATH" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>

                                <TextBox Grid.Column="2" Name="txtDownloadPath" 
                                            Background="#0e121a" 
                                            BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                            Foreground="{StaticResource CyberpunkTextBrush}" 
                                            CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                            Height="30"
                                            VerticalContentAlignment="Center"
                                            IsReadOnly="True"/>

                                <Button Grid.Column="4" Name="btnBrowseFolder" Content="BROWSE" Click="BtnBrowseFolder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="80" FontSize="11"/>

                                <Button Grid.Column="6" Name="btnOpenFolder" Content="OPEN FOLDER" Click="BtnOpenFolder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="100" FontSize="11"/>
                            </Grid>

                            <!-- Row 2: Folder Actions -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "FOLDER ACTIONS" Label -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- MERGE FOLDERS button -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- SPLIT FOLDERS button -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- COMPRESS BOOKS button -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- EXTRACT BOOKS button -->
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/> <!-- SEARCH Label -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>    <!-- Search Textbox -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="FOLDER ACTIONS" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Name="btnMergeFolders" Content="MERGE FOLDERS" Click="BtnMergeFolders_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="130" FontSize="11"/>
                                <Button Grid.Column="4" Name="btnSplitFolders" Content="SPLIT FOLDERS" Click="BtnSplitFolders_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="130" FontSize="11"/>
                                <Button Grid.Column="6" Name="btnCompressBooks" Content="COMPRESS BOOKS" Click="BtnCompressBooks_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="135" FontSize="11"/>
                                <Button Grid.Column="8" Name="btnExtractBooks" Content="EXTRACT BOOKS" Click="BtnExtractBooks_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="130" FontSize="11"/>

                                <TextBlock Grid.Column="10" Text="SEARCH" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="12" Name="txtFilter" 
                                         TextChanged="TxtFilter_TextChanged"
                                         Background="#0e121a" 
                                         BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                         Foreground="{StaticResource CyberpunkTextBrush}" 
                                         CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                         Height="30"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Tìm kiếm tên truyện..."/>
                            </Grid>

                            <!-- Row 4: Chapter Selection -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="CHAPTER SELECTION" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Name="txtChapterSelection"
                                         Background="#0e121a"
                                         BorderBrush="{StaticResource CyberpunkBorderBrush}"
                                         Foreground="{StaticResource CyberpunkTextBrush}"
                                         CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                         Height="28"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Nhập chap cần tải. VD: 1-10;15;20-25 (để trống = tải tất cả)"/>
                            </Grid>

                            <!-- Row 6: Connections and Actions -->
                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "CONNECTION" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox connections -->
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/> <!-- "MULTI DOWNLOAD" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox multi download -->
                                    <ColumnDefinition Width="*"/>   <!-- Spacer / Stretch -->
                                    <ColumnDefinition Width="Auto"/> <!-- START DOWNLOAD button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- PAUSE button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- STOP button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- RETRY ERRORS button -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="CONNECTION" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2" Name="cmbConnections" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="30"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectedIndex="0">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CyberpunkComboBoxItemStyle}"/>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="32"/>
                                </ComboBox>

                                <TextBlock Grid.Column="4" Text="DOWNLOAD MULTIPLE BOOK" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="6" Name="cmbMultiDownload" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="30"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectedIndex="1"
                                          SelectionChanged="CmbMultiDownload_SelectionChanged">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CyberpunkComboBoxItemStyle}"/>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                </ComboBox>

                                <TextBlock Grid.Column="7" Text="{x:Static local:BuildInfo.DisplayText}"
                                           Foreground="{StaticResource CyberpunkYellowBrush}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,10,0"/>

                                <Button Grid.Column="8" Name="btnStartDownload" Content="⬇️" Click="BtnStartDownload_Click" Height="35" Width="78" FontSize="13" ToolTip="DOWNLOAD ALL">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonImportant}">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Content" Value="⬇️ ALL"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Grid.Column="12" Name="btnStopDownload" Content="⏹️" Click="BtnStopDownload_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Width="55" FontSize="13" IsEnabled="False" ToolTip="Stop"/>
                                <Button Grid.Column="14" Name="btnRetryErrors" Content="⚠️" Click="BtnRetryErrors_Click" Height="35" Width="78" FontSize="13" ToolTip="RETRY ALL">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Content" Value="⚠️ ALL"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Name="lblStatus" Text="Ready." Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
    </Border>
    </Grid>
    </Grid>
</Window>
