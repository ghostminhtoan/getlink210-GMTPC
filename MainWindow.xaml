<Window x:Class="get_link_manga.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:get_link_manga"
        mc:Ignorable="d"
        Title="NEON LINK SCRAPER v1.0" Height="700" Width="1100"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterScreen"
        SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <!-- Missing resource definitions -->
        <Style x:Key="ToggleButtonSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="{StaticResource CyberpunkBorderBrush}"/>
        </Style>
        <Style x:Key="ProgressBarSuccess" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
            <Setter Property="Background" Value="{StaticResource CyberpunkBorderBrush}"/>
        </Style>
        <Style x:Key="TabControlInLine" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource CyberpunkDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
        </Style>
        <!-- DataGrid Style -->
        <Style x:Key="CyberpunkDataGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="#06090e"/>
            <Setter Property="RowBackground" Value="#06090e"/>
            <Setter Property="AlternatingRowBackground" Value="#0c0f17"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1f293d"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1f293d"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <!-- Column Header Style -->
        <Style x:Key="CyberpunkDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#121622"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1c1122"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row Style -->
        <Style x:Key="CyberpunkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#161f30"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e2d4a"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell Style -->
        <Style x:Key="CyberpunkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="CyberpunkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#0e121a"/>
            <Setter Property="Foreground" Value="DarkGreen"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        
        <!-- ComboBoxItem Style for dropdown items -->
        <Style x:Key="CyberpunkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource CyberpunkCardBrush}"/>
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="Padding" Value="10,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1c1122"/>
                    <Setter Property="Foreground" Value="Red"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e2d4a"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Title Bar / Header -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Grid -->
            <RowDefinition Height="*"/>
            <!-- Shared Actions Footer -->
            <RowDefinition Height="Auto"/>
            <!-- Footer Status Bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CyberpunkPinkBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="CYBERPUNK LINK SCRAPE // CRAWLER SYSTEM" 
                               FontSize="22" 
                               FontWeight="ExtraBold" 
                               Style="{StaticResource CyberpunkHeader}"/>
                    <TextBlock Text="NET FRAMEWORK 4.8 / HANDY CONTROL POWERED" 
                               FontSize="10" 
                               Foreground="{StaticResource CyberpunkCyanBrush}" 
                               FontWeight="Bold"
                               Margin="2,2,0,0"/>
                </StackPanel>

                <!-- Bookmark & History Buttons -->
                <Button Grid.Column="1" Name="btnOpenBookmarks" Content="📌 BOOKMARKS" Click="BtnOpenBookmarks_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" FontSize="11" Padding="10,0"/>
                <Button Grid.Column="3" Name="btnOpenHistory" Content="📜 HISTORY" Click="BtnOpenHistory_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" FontSize="11" Padding="10,0"/>

                <Border Grid.Column="5" BorderBrush="{StaticResource CyberpunkCyanBrush}" BorderThickness="1" CornerRadius="3" Padding="8,4" Background="#121622">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#00ff00" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00ff00" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="SYSTEM ONLINE" FontSize="11" Foreground="#00ff00" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Grid for Content -->
        <Grid Grid.Row="1" Name="gridMainContent" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tab Control for Crawlers (Left Side) -->
            <TabControl Name="tabLeftPanel" Grid.Column="0" Grid.Row="0" Style="{StaticResource TabControlInLine}" Background="Transparent" BorderThickness="0">
                <!-- HentaiForce Tab -->
                <TabItem Header="HENTAIFORCE">
                    <Grid Margin="0,10,0,0">
                        <!-- Left Control Panel -->
                        <Border Name="borderLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Section Title -->
                                    <RowDefinition Height="Auto"/> <!-- URL Input -->
                                    <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                    <RowDefinition Height="Auto"/> <!-- Page Info -->
                                    <RowDefinition Height="Auto"/> <!-- Row Range Input -->
                                    <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                    <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                </Grid.RowDefinitions>

                                <!-- Panel Header -->
                                <TextBlock Grid.Row="0" Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,15"/>

                                <!-- Target URL -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Text="TARGET TAG URL" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBox Name="txtTagUrl" 
                                                Text="https://hentaiforce.net/search?q=%22uncensored%22+%22full+color"
                                                Background="#0e121a" 
                                                BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                Foreground="{StaticResource CyberpunkTextBrush}" 
                                                CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                Height="32"/>
                                </StackPanel>

                                <!-- Fetch Info Action -->
                                <Button Grid.Row="2" Name="btnFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnFetchInfo_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Margin="0,0,0,20"/>

                                <!-- Page Info Status -->
                                <Border Grid.Row="3" Background="#0c0f17" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" Padding="12" CornerRadius="3" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="TARGET PAGE ANALYSIS" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Total Pages Found:" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Name="txtTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" CaretBrush="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="30" HorizontalContentAlignment="Center" TextChanged="TxtTotalPages_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Page Range Input -->
                                <Grid Grid.Row="4" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Scrape & Direct Import Actions -->
                                <Grid Grid.Row="5" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Name="btnScrape" Content="START CRAWLING" Click="BtnScrape_Click" Style="{StaticResource CyberpunkButtonPink}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="2" Name="btnCrawlMore" Content="CRAWL MORE" Click="BtnCrawlMore_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="4" Name="btnPasteDirect" Content="PASTE DIRECT LINK" Click="BtnPasteDirect_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                </Grid>

                                <!-- Progress Logging Panel -->
                                <Grid Grid.Row="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="REAL-TIME CRAWL CONSOLE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Name="btnClearLog" Content="CLEAR" Click="BtnClearLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                    </Grid>
                                    <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox Name="txtLog" 
                                                     Background="Transparent" 
                                                     BorderThickness="0" 
                                                     Foreground="#a8ffb2" 
                                                     FontFamily="Consolas, Courier New" 
                                                     FontSize="11" 
                                                     IsReadOnly="True" 
                                                     AcceptsReturn="True" 
                                                     Padding="10"
                                                     TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- nhentai.net tab -->
                <TabItem Header="nhentai.net">
                    <Grid Margin="0,10,0,0">
                        <Border Name="borderNhentaiLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Section Title -->
                                    <RowDefinition Height="Auto"/> <!-- URL Input -->
                                    <RowDefinition Height="Auto"/> <!-- Sort Option -->
                                    <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                    <RowDefinition Height="Auto"/> <!-- Page Info -->
                                    <RowDefinition Height="Auto"/> <!-- Row Range Input -->
                                    <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                    <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                </Grid.RowDefinitions>

                                <!-- Panel Header -->
                                <TextBlock Grid.Row="0" Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,15"/>

                                <!-- Target URL -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Text="TARGET TAG URL" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBox Name="txtNhentaiTagUrl" 
                                                Text="https://nhentai.net/search?q=%22uncensored%22+%22full+color%22&amp;sort=date"
                                                Background="#0e121a" 
                                                BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                Foreground="{StaticResource CyberpunkTextBrush}" 
                                                CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                Height="32"
                                                TextChanged="TxtNhentaiTagUrl_TextChanged"/>
                                </StackPanel>

<!-- Sort Option -->
                                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                    <TextBlock Text="SORT OPTION" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <ComboBox Name="cmbNhentaiSort" 
                                              Style="{StaticResource CyberpunkComboBox}"
                                              Height="32"
                                              VerticalContentAlignment="Center"
                                              SelectedIndex="0"
                                              SelectionChanged="CmbNhentaiSort_SelectionChanged">
                                        <ComboBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel Background="#121622"/>
                                            </ItemsPanelTemplate>
                                        </ComboBox.ItemsPanel>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CyberpunkComboBoxItemStyle}"/>
                                        </ComboBox.ItemContainerStyle>
                                         <ComboBoxItem Content="Recent" Tag="date"/>
                                         <ComboBoxItem Content="Popular Today" Tag="popular-today"/>
                                         <ComboBoxItem Content="Popular Week" Tag="popular-week"/>
                                         <ComboBoxItem Content="Popular All Time" Tag="popular"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Fetch Info Action -->
                                <Button Grid.Row="3" Name="btnNhentaiFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnNhentaiFetchInfo_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Margin="0,0,0,20"/>

                                <!-- Page Info Status -->
                                <Border Grid.Row="4" Background="#0c0f17" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" Padding="12" CornerRadius="3" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="TARGET PAGE ANALYSIS" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Total Pages Found:" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Name="txtNhentaiTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" CaretBrush="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="30" HorizontalContentAlignment="Center" TextChanged="TxtNhentaiTotalPages_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Page Range Input -->
                                <Grid Grid.Row="5" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtNhentaiPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtNhentaiPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Scrape & Direct Import Actions -->
                                <Grid Grid.Row="6" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Name="btnNhentaiScrape" Content="START CRAWLING" Click="BtnNhentaiScrape_Click" Style="{StaticResource CyberpunkButtonPink}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="2" Name="btnNhentaiCrawlMore" Content="CRAWL MORE" Click="BtnNhentaiCrawlMore_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="4" Name="btnNhentaiPasteDirect" Content="PASTE DIRECT LINK" Click="BtnNhentaiPasteDirect_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                </Grid>

                                <!-- Progress Logging Panel -->
                                <Grid Grid.Row="7">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="REAL-TIME CRAWL CONSOLE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Name="btnClearNhentaiLog" Content="CLEAR" Click="BtnClearNhentaiLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                    </Grid>
                                    <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox Name="txtNhentaiLog" 
                                                     Background="Transparent" 
                                                     BorderThickness="0" 
                                                     Foreground="#a8ffb2" 
                                                     FontFamily="Consolas, Courier New" 
                                                     FontSize="11" 
                                                     IsReadOnly="True" 
                                                     AcceptsReturn="True" 
                                                     Padding="10"
                                                     TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- vi-hentai.pro tab -->
                <TabItem Header="vi-hentai.pro">
                    <Grid Margin="0,10,0,0">
                        <Border Name="borderViHentaiLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Section Title -->
                                    <RowDefinition Height="Auto"/> <!-- URL Input -->
                                    <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                    <RowDefinition Height="Auto"/> <!-- Page Info -->
                                    <RowDefinition Height="Auto"/> <!-- Row Range Input -->
                                    <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                    <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                </Grid.RowDefinitions>

                                <!-- Panel Header -->
                                <TextBlock Grid.Row="0" Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,15"/>

                                <!-- Target URL -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Text="TARGET TAG URL" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBox Name="txtViHentaiTagUrl" 
                                                Text="https://vi-hentai.pro/the-loai/khong-che"
                                                Background="#0e121a" 
                                                BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                Foreground="{StaticResource CyberpunkTextBrush}" 
                                                CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                Height="32"/>
                                </StackPanel>

                                <!-- Fetch Info Action -->
                                <Button Grid.Row="2" Name="btnViHentaiFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnViHentaiFetchInfo_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Margin="0,0,0,20"/>

                                <!-- Page Info Status -->
                                <Border Grid.Row="3" Background="#0c0f17" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" Padding="12" CornerRadius="3" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="TARGET PAGE ANALYSIS" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Total Pages Found:" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Name="txtViHentaiTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" CaretBrush="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="30" HorizontalContentAlignment="Center" TextChanged="TxtViHentaiTotalPages_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Page Range Input -->
                                <Grid Grid.Row="4" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtViHentaiPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtViHentaiPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Scrape & Direct Import Actions -->
                                <Grid Grid.Row="5" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Name="btnViHentaiScrape" Content="START CRAWLING" Click="BtnViHentaiScrape_Click" Style="{StaticResource CyberpunkButtonPink}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="2" Name="btnViHentaiCrawlMore" Content="CRAWL MORE" Click="BtnViHentaiCrawlMore_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="4" Name="btnViHentaiPasteDirect" Content="PASTE DIRECT LINK" Click="BtnViHentaiPasteDirect_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="6" Name="btnViHentaiReverseOrder" Content="REVERSE ORDER" Click="BtnViHentaiReverseOrder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                </Grid>

                                <!-- Progress Logging Panel -->
                                <Grid Grid.Row="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="REAL-TIME CRAWL CONSOLE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Name="btnClearViHentaiLog" Content="CLEAR" Click="BtnClearViHentaiLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                    </Grid>
                                    <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox Name="txtViHentaiLog" 
                                                     Background="Transparent" 
                                                     BorderThickness="0" 
                                                     Foreground="#a8ffb2" 
                                                     FontFamily="Consolas, Courier New" 
                                                     FontSize="11" 
                                                     IsReadOnly="True" 
                                                     AcceptsReturn="True" 
                                                     Padding="10"
                                                     TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- truyenqq tab -->
                <TabItem Header="truyenqq">
                    <Grid Margin="0,10,0,0">
                        <Border Name="borderTruyenqqLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Section Title -->
                                    <RowDefinition Height="Auto"/> <!-- URL Input -->
                                    <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                    <RowDefinition Height="Auto"/> <!-- Page Info -->
                                    <RowDefinition Height="Auto"/> <!-- Row Range Input -->
                                    <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                    <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                </Grid.RowDefinitions>

                                <!-- Panel Header -->
                                <TextBlock Grid.Row="0" Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,15"/>

                                <!-- Target URL -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Text="TARGET TAG URL" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBox Name="txtTruyenqqTagUrl" 
                                                Text="https://truyenqqto.com/the-loai/anime-62"
                                                Background="#0e121a" 
                                                BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                Foreground="{StaticResource CyberpunkTextBrush}" 
                                                CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                Height="32"/>
                                </StackPanel>

                                <!-- Fetch Info Action -->
                                <Button Grid.Row="2" Name="btnTruyenqqFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnTruyenqqFetchInfo_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35" Margin="0,0,0,20"/>

                                <!-- Page Info Status -->
                                <Border Grid.Row="3" Background="#0c0f17" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" Padding="12" CornerRadius="3" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="TARGET PAGE ANALYSIS" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Total Pages Found:" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Name="txtTruyenqqTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" CaretBrush="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="30" HorizontalContentAlignment="Center" TextChanged="TxtTruyenqqTotalPages_TextChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Page Range Input -->
                                <Grid Grid.Row="4" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtTruyenqqPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Name="txtTruyenqqPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Scrape & Direct Import Actions -->
                                <Grid Grid.Row="5" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Name="btnTruyenqqScrape" Content="START CRAWLING" Click="BtnTruyenqqScrape_Click" Style="{StaticResource CyberpunkButtonPink}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="2" Name="btnTruyenqqCrawlMore" Content="CRAWL MORE" Click="BtnTruyenqqCrawlMore_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="4" Name="btnTruyenqqPasteDirect" Content="PASTE DIRECT LINK" Click="BtnTruyenqqPasteDirect_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                    <Button Grid.Column="6" Name="btnTruyenqqReverseOrder" Content="REVERSE ORDER" Click="BtnTruyenqqReverseOrder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="40" FontSize="11"/>
                                </Grid>

                                <!-- Progress Logging Panel -->
                                <Grid Grid.Row="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="REAL-TIME CRAWL CONSOLE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Name="btnClearTruyenqqLog" Content="CLEAR" Click="BtnClearTruyenqqLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                    </Grid>
                                    <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox Name="txtTruyenqqLog" 
                                                     Background="Transparent" 
                                                     BorderThickness="0" 
                                                     Foreground="#a8ffb2" 
                                                     FontFamily="Consolas, Courier New" 
                                                     FontSize="11" 
                                                     IsReadOnly="True" 
                                                     AcceptsReturn="True" 
                                                     Padding="10"
                                                     TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Right Output Panel (Shared) -->
            <Border Name="borderRightPanel" Grid.Column="2" Grid.Row="0" Style="{StaticResource CyberpunkCard}" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Filter & Sort Toolbar -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                        <RowDefinition Height="Auto"/> <!-- Download Section -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="EXTRACTED GALLERY LINKS" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>

                        <!-- Word Wrap Switch -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="WORD WRAP" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ToggleButton Name="chkWordWrap" Style="{StaticResource ToggleButtonSwitch}" Height="20" Width="40" Background="#121622" BorderBrush="{StaticResource CyberpunkBorderBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="3" Background="#1c1122" BorderBrush="{StaticResource CyberpunkPinkBrush}" BorderThickness="1" CornerRadius="3" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total Books: " Foreground="{StaticResource CyberpunkTextBrush}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Name="lblLinkCount" Text="0" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Toolbar for Filtering and Sorting -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        
                        <TextBox Name="txtFilter" 
                                    TextChanged="TxtFilter_TextChanged"
                                    Background="#0e121a" 
                                    BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                    Foreground="{StaticResource CyberpunkTextBrush}" 
                                    CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                    Height="30"
                                    VerticalContentAlignment="Center"/>
                        
                        <Button Grid.Column="2" Name="btnSortByName" Content="SORT BY NAME" Click="BtnSortByName_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="120" FontSize="11"/>
                        <Button Grid.Column="4" Name="btnRestoreOrder" Content="RESTORE ORDER" Click="BtnRestoreOrder_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="120" FontSize="11"/>
                        <Button Grid.Column="6" Name="btnDuplicateName" Content="DUPLICATE NAME" Click="BtnDuplicateName_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="120" FontSize="11"/>
                        <Button Grid.Column="8" Name="btnNoLinkViHentai" Content="NO LINK (VI-HENTAI)" Click="BtnNoLinkViHentai_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="150" FontSize="11"/>
                        <Button Grid.Column="10" Name="btnReverseOrder" Content="REVERSE ORDER" Click="BtnReverseOrder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="150" FontSize="11"/>
                    </Grid>

                    <!-- Scraped links DataGrid -->
                    <DataGrid Grid.Row="2" 
                              Name="dgResults"
                              Style="{StaticResource CyberpunkDataGrid}"
                              ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                              RowStyle="{StaticResource CyberpunkDataGridRow}"
                              CellStyle="{StaticResource CyberpunkDataGridCell}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              PreviewKeyDown="DgResults_PreviewKeyDown"
                              PreviewTextInput="DgResults_PreviewTextInput"
                              MouseDoubleClick="DgResults_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.ScrollUnit="Row"
                              EnableRowVirtualization="True"
                              Margin="0,0,0,15">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Tích chọn dòng đang bôi đen (Check Selected)" Click="MenuCheckSelected_Click"/>
                                <MenuItem Header="Bỏ tích dòng đang bôi đen (Uncheck Selected)" Click="MenuUncheckSelected_Click"/>
                                <MenuItem Header="Đảo ngược trạng thái tích (Invert Checked)" Click="MenuInvertChecked_Click"/>
                                <Separator/>
                                <MenuItem Header="📌 Bookmark dòng đang chọn" Click="MenuBookmarkSelected_Click"/>
                                <MenuItem Header="🌐 Mở link trong trình duyệt" Click="MenuOpenInBrowser_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy link các dòng đang chọn (Copy Selected Links)" Click="MenuCopySelectedLinks_Click"/>
                                <Separator/>
                                <MenuItem Header="Xóa các dòng đang bôi đen (Delete Selected)" Click="MenuDeleteSelected_Click"/>
                                <MenuItem Header="Xóa các dòng đã tích (Delete Checked)" Click="MenuDeleteChecked_Click"/>
                                <Separator/>
                                <MenuItem Header="Tải các dòng đang bôi đen (Download highlighted lines)" Click="MenuDownloadSelected_Click"/>
                                <MenuItem Header="Tải các dòng đã tích (Download selected lines)" Click="MenuDownloadChecked_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <!-- Checkbox Column -->
                            <DataGridTemplateColumn Width="45">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Center">
                                        <CheckBox Name="chkSelectAll" Click="ChkSelectAll_Click"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Gallery Details Column (Vertical stack of Name and Link) -->
                            <DataGridTemplateColumn Header="GALLERY DETAILS (TITLE &amp; URL)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5,4" Orientation="Vertical">
                                            <!-- Title -->
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="Bold" 
                                                       FontSize="12"
                                                       Margin="0,0,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CyberpunkYellowBrush}"/>
                                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=chkWordWrap}" Value="True">
                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasNoChapters}" Value="True">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Link -->
                                            <TextBlock Text="{Binding Link}" 
                                                       Foreground="{StaticResource CyberpunkCyanBrush}" 
                                                       FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=chkWordWrap}" Value="True">
                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Chapter Count -->
                                            <TextBlock Text="{Binding LinkCount, StringFormat=Chapters: {0}}" 
                                                       Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                                       FontSize="10"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                             <!-- Status Column -->
                             <DataGridTemplateColumn Header="STATUS" Width="180">
                                 <DataGridTemplateColumn.CellTemplate>
                                     <DataTemplate>
                                         <Grid Margin="5,4">
                                             <Grid.Style>
                                                 <Style TargetType="Grid">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding Status}" Value="{x:Null}">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                         <DataTrigger Binding="{Binding Status}" Value="">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </Grid.Style>
                                             <Grid.RowDefinitions>
                                                 <RowDefinition Height="Auto"/>
                                                 <RowDefinition Height="Auto"/>
                                             </Grid.RowDefinitions>

                                             <!-- Row 0: Status Text, Action Buttons and Error Button -->
                                             <Grid Grid.Row="0" Margin="0,0,0,4">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                 </Grid.ColumnDefinitions>

                                                 <!-- Status Display -->
                                                 <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                     <TextBlock FontSize="11" FontWeight="Bold" Foreground="{StaticResource CyberpunkCyanBrush}">
                                                         <TextBlock.Style>
                                                             <Style TargetType="TextBlock">
                                                                 <Setter Property="Text" Value="⏳ Waiting"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                         <Setter Property="Text" Value="⬇️ Loading"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                         <Setter Property="Text" Value="✅ Done"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                         <Setter Property="Text" Value="❌ Error"/>
                                                                         <Setter Property="Foreground" Value="Red"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                         <Setter Property="Text" Value="⏸️ Paused"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </TextBlock.Style>
                                                     </TextBlock>
                                                 </StackPanel>

                                                 <!-- Row Buttons -->
                                                 <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                                                     <!-- Play/Resume Button -->
                                                     <Button Content="▶️" Click="BtnRowResume_Click" Width="22" Height="18" Margin="1,0" Padding="0" FontSize="8" ToolTip="Resume download">
                                                         <Button.Style>
                                                             <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                     <!-- Pause Button -->
                                                     <Button Content="⏸️" Click="BtnRowPause_Click" Width="22" Height="18" Margin="1,0" Padding="0" FontSize="8" ToolTip="Pause download">
                                                         <Button.Style>
                                                             <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                     <!-- Stop Button -->
                                                     <Button Content="⏹️" Click="BtnRowStop_Click" Width="22" Height="18" Margin="1,0" Padding="0" FontSize="8" ToolTip="Stop download">
                                                         <Button.Style>
                                                             <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonPink}">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Queued">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                 </StackPanel>

                                                 <!-- Error Button -->
                                                 <Button Grid.Column="2" Content="{Binding ErrorCount, StringFormat=Err: {0}}" 
                                                         Click="BtnShowErrors_Click"
                                                         VerticalAlignment="Center"
                                                         Margin="4,0,0,0" Height="18" Padding="3,0" FontSize="9">
                                                     <Button.Style>
                                                         <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding ErrorCount, Converter={x:Static local:GreaterThanZeroConverter.Instance}}" Value="True">
                                                                     <Setter Property="Visibility" Value="Visible"/>
                                                                     <Setter Property="Background" Value="#ff2222"/>
                                                                     <Setter Property="BorderBrush" Value="#ff4444"/>
                                                                     <Setter Property="Foreground" Value="White"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Button.Style>
                                                 </Button>
                                             </Grid>

                                             <!-- Row 1: Progress Bar with Text Overlay -->
                                             <Grid Grid.Row="1" Height="14" Margin="0,2,0,0">
                                                 <Grid.Style>
                                                     <Style TargetType="Grid">
                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                             <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Grid.Style>

                                                 <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100" Foreground="{StaticResource CyberpunkCyanBrush}" Style="{StaticResource ProgressBarSuccess}" Height="14" VerticalAlignment="Center"/>
                                                 
                                                 <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}" 
                                                            Foreground="Black" 
                                                            FontSize="9" 
                                                            FontWeight="Bold"
                                                            HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                             </Grid>
                                         </Grid>
                                     </DataTemplate>
                                 </DataGridTemplateColumn.CellTemplate>
                             </DataGridTemplateColumn>

                             <!-- Process Column -->
                             <DataGridTemplateColumn Header="PROCESS" Width="200">
                                 <DataGridTemplateColumn.CellTemplate>
                                     <DataTemplate>
                                         <StackPanel Margin="5,4" Orientation="Vertical">
                                             <StackPanel.Style>
                                                 <Style TargetType="StackPanel">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding Status}" Value="{x:Null}">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                         <DataTrigger Binding="{Binding Status}" Value="">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </StackPanel.Style>

                                             <!-- Row 1: Downloading Chapter -->
                                             <TextBlock Text="{Binding DownloadingChapter}" 
                                                        Foreground="{StaticResource CyberpunkYellowBrush}" 
                                                        FontSize="11" 
                                                        FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis"/>

                                             <!-- Row 2: Page Progress -->
                                             <TextBlock Text="{Binding DownloadingPageProgress}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        FontSize="10" 
                                                        Margin="0,2,0,0"/>
                                         </StackPanel>
                                     </DataTemplate>
                                 </DataGridTemplateColumn.CellTemplate>
                             </DataGridTemplateColumn>

                            <!-- Action Buttons Column -->
                            <DataGridTemplateColumn Header="ACTIONS" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="🌐" 
                                                    Tag="{Binding Link}" 
                                                    Click="BtnOpenLinkInRow_Click"
                                                    Width="30" Height="28" Margin="2,0"
                                                    Style="{StaticResource CyberpunkButtonCyan}"
                                                    FontSize="13" Padding="0"
                                                    ToolTip="Mở link trong trình duyệt"/>
                                            <Button Content="⬇️" 
                                                    Click="BtnDownloadSingleInRow_Click"
                                                    Width="30" Height="28" Margin="2,0"
                                                    Style="{StaticResource CyberpunkButtonPink}"
                                                    FontSize="13" Padding="0"
                                                    ToolTip="Tải truyện này"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Download Section -->
                    <Border Grid.Row="3" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Path Config -->
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/> <!-- Folder Actions (Merge/Split) -->
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/> <!-- Chapter Selection -->
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/> <!-- Connections and Start Download -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: Path Config -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "DOWNLOAD PATH" Label -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>    <!-- Textbox for folder path -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- BROWSE button -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- OPEN FOLDER button -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="DOWNLOAD PATH" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>

                                <TextBox Grid.Column="2" Name="txtDownloadPath" 
                                            Background="#0e121a" 
                                            BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                            Foreground="{StaticResource CyberpunkTextBrush}" 
                                            CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                            Height="30"
                                            VerticalContentAlignment="Center"
                                            IsReadOnly="True"/>

                                <Button Grid.Column="4" Name="btnBrowseFolder" Content="BROWSE" Click="BtnBrowseFolder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="80" FontSize="11"/>

                                <Button Grid.Column="6" Name="btnOpenFolder" Content="OPEN FOLDER" Click="BtnOpenFolder_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="100" FontSize="11"/>
                            </Grid>

                            <!-- Row 2: Folder Actions -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "FOLDER ACTIONS" Label -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- MERGE FOLDERS button -->
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/> <!-- SPLIT FOLDERS button -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="FOLDER ACTIONS" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Name="btnMergeFolders" Content="MERGE FOLDERS" Click="BtnMergeFolders_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="130" FontSize="11"/>
                                <Button Grid.Column="4" Name="btnSplitFolders" Content="SPLIT FOLDERS" Click="BtnSplitFolders_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="130" FontSize="11"/>
                            </Grid>

                            <!-- Row 4: Chapter Selection -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="CHAPTER SELECTION" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Name="txtChapterSelection"
                                         Background="#0e121a"
                                         BorderBrush="{StaticResource CyberpunkBorderBrush}"
                                         Foreground="{StaticResource CyberpunkTextBrush}"
                                         CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                         Height="28"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Nhập chap cần tải. VD: 1-10;15;20-25 (để trống = tải tất cả)"/>
                            </Grid>

                            <!-- Row 6: Connections and Actions -->
                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "CONNECTION" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox connections -->
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/> <!-- "MULTI DOWNLOAD" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox multi download -->
                                    <ColumnDefinition Width="*"/>   <!-- Spacer / Stretch -->
                                    <ColumnDefinition Width="Auto"/> <!-- START DOWNLOAD button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- PAUSE button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- STOP button -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="CONNECTION" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2" Name="cmbConnections" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="30"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectedIndex="0">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CyberpunkComboBoxItemStyle}"/>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="32"/>
                                </ComboBox>

                                <TextBlock Grid.Column="4" Text="MULTI DOWNLOAD" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="6" Name="cmbMultiDownload" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="30"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectedIndex="1">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CyberpunkComboBoxItemStyle}"/>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                </ComboBox>

                                <Button Grid.Column="8" Name="btnStartDownload" Content="▶️" Click="BtnStartDownload_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="45" FontSize="11" ToolTip="Start Download"/>
                                <Button Grid.Column="10" Name="btnPauseDownload" Content="⏸️" Click="BtnPauseDownload_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="30" Width="45" FontSize="11" IsEnabled="False" ToolTip="Pause / Resume"/>
                                <Button Grid.Column="12" Name="btnStopDownload" Content="⏹️" Click="BtnStopDownload_Click" Style="{StaticResource CyberpunkButtonPink}" Height="30" Width="45" FontSize="11" IsEnabled="False" ToolTip="Stop"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Shared Actions Footer -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="COPY LINKS" Click="BtnCopyLinksOnly_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35"/>
            <Button Grid.Column="2" Content="COPY NAME+LINK" Click="BtnCopyNamesAndLinks_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35"/>
            <Button Grid.Column="4" Content="SAVE MD FILE" Click="BtnSave_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35"/>
            <Button Grid.Column="6" Content="LOAD MD FILE" Click="BtnLoad_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35"/>
            <Button Grid.Column="8" Content="CLEAR" Click="BtnClear_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="35"/>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Name="lblStatus" Text="Ready." Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
