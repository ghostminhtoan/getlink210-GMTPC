‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВЎГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬В ГѓВўГўвЂљВ¬ГўвЂћВўГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г‚В ГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓВўГўв‚¬ЕѕГ‚ВўГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВўГѓЖ’Г†вЂ™ГѓвЂљГ‚ВўГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚В¬ГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г‚В¦ГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВЎГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬В ГѓВўГўвЂљВ¬ГўвЂћВўГѓЖ’Г†вЂ™ГѓвЂљГ‚ВўГѓЖ’Г‚ВўГѓВўГўвЂљВ¬Г…ВЎГѓвЂљГ‚В¬ГѓЖ’Гўв‚¬В¦ГѓвЂљГ‚ВЎГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚В»ГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬В ГѓВўГўвЂљВ¬ГўвЂћВўГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г‚В ГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓВўГўв‚¬ЕѕГ‚ВўГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВўГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬В ГѓВўГўвЂљВ¬ГўвЂћВўГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВўГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВўГѓЖ’Г†вЂ™ГѓвЂљГ‚ВўГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚В¬ГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г‚В¦ГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВЎГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚В¬ГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬В ГѓВўГўвЂљВ¬ГўвЂћВўГѓЖ’Г†вЂ™ГѓвЂљГ‚ВўГѓЖ’Г‚ВўГѓВўГўвЂљВ¬Г…ВЎГѓвЂљГ‚В¬ГѓЖ’Гўв‚¬В¦ГѓвЂљГ‚ВЎГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВЎn..."/>
                            </Grid>

                            <!-- Row 2: Folder Actions -->
                            <Grid Grid.Row="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "FOLDER ACTIONS" Label -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- COMPRESS BOOKS button -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/> <!-- EXTRACT BOOKS button -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/> <!-- Download Folder type button -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="txtFolderActionsLabel" Grid.Column="0" Text="FOLDER ACTIONS" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Name="btnCompressBooks" Content="COMPRESS" Click="BtnCompressBooks_Click" Style="{StaticResource CompactCyanButton}" Width="94" Margin="0"/>
                                <Button Grid.Column="4" Name="btnExtractBooks" Content="EXTRACT" Click="BtnExtractBooks_Click" Style="{StaticResource CompactPinkButton}" Width="86" Margin="0"/>
                                <Button Grid.Column="6" Name="btnDownloadFolderType" Content="Download Folder type" Click="BtnDownloadFolderType_Click" Style="{StaticResource CompactCyanButton}" Width="150" Margin="0"/>

                            </Grid>

                            <Grid Grid.Row="6" Name="archiveProgressPanel" Margin="0,8,0,6" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="txtArchiveProgressLabel"
                                           Grid.Column="0"
                                           Text="ARCHIVE PROGRESS"
                                           Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>

                                <ProgressBar Name="archiveProgressBar"
                                             Grid.Column="2"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Height="14"
                                             VerticalAlignment="Center"
                                             Foreground="{StaticResource CyberpunkCyanBrush}"
                                             Style="{StaticResource ProgressBarSuccess}"/>

                                <TextBlock Name="txtArchiveProgressValue"
                                           Grid.Column="4"
                                           Text="0%"
                                           Foreground="{StaticResource CyberpunkYellowBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>

                                <Button Name="btnArchivePause"
                                        Grid.Column="6"
                                        Content="PAUSE"
                                        Click="BtnArchivePause_Click"
                                        Style="{StaticResource CompactCyanButton}"
                                        Width="72"
                                        Margin="0"
                                        IsEnabled="False"/>

                                <Button Name="btnArchiveStop"
                                        Grid.Column="8"
                                        Content="STOP"
                                        Click="BtnArchiveStop_Click"
                                        Style="{StaticResource CompactPinkButton}"
                                        Width="68"
                                        Margin="0"
                                        IsEnabled="False"/>
                            </Grid>

                            <!-- Row 4: Connections and Actions -->
                            <Grid Grid.Row="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "CONNECTION" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox connections -->
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/> <!-- "MULTI DOWNLOAD" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox multi download -->
                                    <ColumnDefinition Width="*"/>   <!-- Spacer / Stretch -->
                                    <ColumnDefinition Width="Auto"/> <!-- START DOWNLOAD button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- STOP button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- RETRY ERRORS button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- RETRY ALL button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- ERROR LOG button -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="txtConnectionLabel" Grid.Column="0" Text="CONNECTION" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2" Name="cmbConnections" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="26"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectionChanged="CmbConnections_SelectionChanged"
                                          SelectedIndex="2">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="32"/>
                                </ComboBox>

                                <TextBlock Name="txtDownloadMultipleBookLabel" Grid.Column="4" Text="DOWNLOAD MULTIPLE BOOK" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="6" Name="cmbMultiDownload" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="26"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectedIndex="1"
                                          SelectionChanged="CmbMultiDownload_SelectionChanged">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                </ComboBox>

                                <Grid Grid.Column="7" Margin="0,0,10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton Grid.Column="0"
                                                  Name="tglShutdownAfterDownload"
                                                  Style="{StaticResource ShutdownActionToggleButton}"
                                                  Checked="TglShutdownAfterDownload_Checked"
