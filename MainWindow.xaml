                                                <TextBox Name="txtHentaieraTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" CaretBrush="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="32" HorizontalContentAlignment="Center" TextChanged="TxtHentaieraTotalPages_TextChanged"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtHentaieraPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtHentaieraPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="4" Height="0" Margin="0"/>

                                        <!-- Scrape & Direct Import Actions -->
                                        <Grid Grid.Row="5" Margin="0,15,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnHentaieraScrape" Content="GET LINK" Click="BtnHentaieraScrape_Click" Style="{StaticResource WideActionButton}"/>
                                            <Button Grid.Column="2" Name="btnHentaieraCrawlMore" Content="GET MORE" Click="BtnHentaieraCrawlMore_Click" Style="{StaticResource WideActionButton}"/>
                                            <Button Grid.Column="4" Name="btnHentaieraPasteDirect" Content="PASTE DIRECT LINK" Click="BtnHentaieraPasteDirect_Click" Style="{StaticResource WideActionButton}"/>
                                        </Grid>

                                        <!-- Check Error Panel -->
                                        <Grid Grid.Row="6" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="CHECK ERROR" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CheckErrors.Count, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=TOTAL: {0}}" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Button Grid.Column="2" Name="btnClearCheckErrorsHentaiera" Content="CLEAR" Click="BtnClearCheckErrors_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                            <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                                <DataGrid Name="dgCheckErrorsHentaiera"
                                                          ItemsSource="{Binding CheckErrors, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Foreground="{StaticResource CyberpunkTextBrush}"
                                                          HeadersVisibility="Column"
                                                          RowHeaderWidth="0"
                                                          GridLinesVisibility="Horizontal"
                                                          HorizontalGridLinesBrush="#1f293d"
                                                          VerticalGridLinesBrush="#1f293d"
                                                          ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                                                          RowStyle="{StaticResource CyberpunkDataGridRow}"
                                                          CellStyle="{StaticResource CyberpunkDataGridCell}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="TIME" Binding="{Binding LastSeen, StringFormat=HH:mm:ss}" Width="85" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                        <DataGridTextColumn Header="BOOK" Binding="{Binding DisplayBook}" Width="260" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                        <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorMessage}" Width="300" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Border>
                                            <Grid Visibility="Collapsed">
                                                <RichTextBox Name="txtHentaieraLog" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0" Foreground="#a8ffb2" FontFamily="Consolas, Courier New" FontSize="11" IsReadOnly="True" Padding="10"/>
                                                <ToggleButton Name="chkAutoScrollHentaieraLog" Style="{StaticResource ToggleButtonSwitch}" IsChecked="True" Height="16" Width="32"/>
                                                <Button Name="btnClearHentaieraLog" Content="CLEAR" Click="BtnClearHentaieraLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>
        </TabItem>

