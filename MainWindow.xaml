                                            <Button Grid.Column="4" Name="btnHentaieraPasteDirect" Content="PASTE DIRECT LINK" Click="BtnHentaieraPasteDirect_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="48" FontSize="12"/>
