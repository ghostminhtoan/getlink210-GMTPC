<Window x:Class="get_link_manga.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:get_link_manga"
        mc:Ignorable="d"
        Title="Comic-GMTPC v1.0" Height="850" Width="1400"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterScreen"
        SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <!-- Missing resource definitions -->
        <Style x:Key="ToggleButtonSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#121622"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BackgroundBorder" 
                                CornerRadius="10" 
                                Background="#121622" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Ellipse x:Name="Thumb" 
                                         Fill="#888888" 
                                         Width="12" Height="12" 
                                         HorizontalAlignment="Left" 
                                         Margin="3,0,3,0"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#172e42"/>
                                <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="{StaticResource CyberpunkCyanBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource CyberpunkCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#121622"/>
                                <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ProgressBarSuccess" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
            <Setter Property="Background" Value="{StaticResource CyberpunkBorderBrush}"/>
        </Style>
        <Style x:Key="TabControlInLine" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource CyberpunkDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
        </Style>
        <!-- DataGrid Style -->
        <Style x:Key="CyberpunkDataGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="#06090e"/>
            <Setter Property="RowBackground" Value="#06090e"/>
            <Setter Property="AlternatingRowBackground" Value="#0c0f17"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1f293d"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1f293d"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <!-- Column Header Style -->
        <Style x:Key="CyberpunkDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#121622"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1c1122"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkPinkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row Style -->
        <Style x:Key="CyberpunkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#161f30"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e2d4a"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell Style -->
        <Style x:Key="CyberpunkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="CyberpunkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#0e121a"/>
            <Setter Property="Foreground" Value="DarkGreen"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        
        <!-- ComboBoxItem Style for dropdown items -->
        <Style x:Key="CyberpunkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource CyberpunkCardBrush}"/>
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="Padding" Value="10,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1c1122"/>
                    <Setter Property="Foreground" Value="Red"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1e2d4a"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Custom TabItem Style -->
        <Style x:Key="CyberpunkTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="#0e121a"/>
            <Setter Property="BorderBrush" Value="#1f293d"/>
            <Setter Property="Foreground" Value="#c8d4e2"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1,1,1,3" 
                                Margin="0,0,4,0" 
                                CornerRadius="4,4,0,0" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                Cursor="Hand">
                            <TextBlock x:Name="headerText" 
                                       Text="{TemplateBinding Header}"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#121622"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="#c8d4e2"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#171f2f"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="#ffffff"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#171f2f"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Title Bar / Header -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Grid -->
            <RowDefinition Height="*"/>
            <!-- Footer Status Bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>



        <!-- Grid for Content -->
        <Grid Grid.Row="1" Name="gridMainContent" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tab Control for Crawlers (Left Side) -->
            <!-- Tab Control for Crawlers (Left Side) -->
            <TabControl Name="tabLeftPanel" Grid.Column="0" Grid.Row="0" Style="{StaticResource TabControlInLine}" Background="Transparent" BorderThickness="0">
                <!-- MANGA Parent Tab -->
                <TabItem Header="MANGA" Style="{StaticResource CyberpunkTabItem}" Tag="{StaticResource CyberpunkCyanBrush}">
                    <TabControl Name="tabManga" Style="{StaticResource TabControlInLine}" Background="Transparent" BorderThickness="0">
                        <!-- truyenqq tab -->
                        <TabItem Header="truyenqq" Style="{StaticResource CyberpunkTabItem}">
                            <TabItem.Tag>
                                <SolidColorBrush Color="#00ff66"/>
                            </TabItem.Tag>
                            <Grid Margin="0,10,0,0">
                                <Border Name="borderTruyenqqLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Section Title -->
                                            <RowDefinition Height="Auto"/> <!-- URL Input -->
                                            <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                            <RowDefinition Height="Auto"/> <!-- Page Info -->
                                            <RowDefinition Height="0"/>    <!-- Row Range Input -->
                                            <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                            <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="📜 HISTORY" Click="BtnOpenHistory_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="25" FontSize="10" Padding="8,0" VerticalAlignment="Center"/>
                                            <Button Grid.Column="3" Content="📌 BOOKMARKS" Click="BtnOpenBookmarks_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="25" FontSize="10" Padding="8,0" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Target URL -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                            <TextBlock Text="DOWNLOAD MULTIPLE WITH TAG OR ARTIST" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <TextBox Name="txtTruyenqqTagUrl" 
                                                        Text="https://truyenqqko.com/the-loai/action-26"
                                                        Background="#0e121a" 
                                                        BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                        Height="32"/>
                                        </StackPanel>

                                        <!-- Fetch Info Action -->
                                        <Grid Grid.Row="2" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnTruyenqqFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnTruyenqqFetchInfo_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="45" FontSize="12"/>
                                            <Button Grid.Column="2" Name="btnTruyenqqFetchCaptcha" Content="DELETE COOKIE" Click="BtnCaptcha_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35"/>
                                        </Grid>

                                        <!-- Page Info Status (TOTAL, FROM, TO pages all on the same row) -->
                                        <Grid Grid.Row="3" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="TOTAL PAGES" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtTruyenqqTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="32" HorizontalContentAlignment="Center" TextChanged="TxtTruyenqqTotalPages_TextChanged"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtTruyenqqPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtTruyenqqPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Page Range Input (Unused, height set to 0) -->
                                        <Grid Grid.Row="4" Height="0" Margin="0"/>

                                        <!-- Scrape & Direct Import Actions -->
                                        <Grid Grid.Row="5" Margin="0,15,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnTruyenqqScrape" Content="GET LINK" Click="BtnTruyenqqScrape_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="48" FontSize="12"/>
                                            <Button Grid.Column="2" Name="btnTruyenqqCrawlMore" Content="GET MORE" Click="BtnTruyenqqCrawlMore_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="48" FontSize="12"/>
                                            <Button Grid.Column="4" Name="btnTruyenqqPasteDirect" Content="PASTE DIRECT LINK" Click="BtnTruyenqqPasteDirect_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="48" FontSize="12"/>
                                        </Grid>

                                        <!-- Check Error Panel -->
                                        <Grid Grid.Row="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="CHECK ERROR" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CheckErrors.Count, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=TOTAL: {0}}" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Button Grid.Column="2" Name="btnClearCheckErrorsTruyenqq" Content="CLEAR" Click="BtnClearCheckErrors_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                            <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                                <DataGrid Name="dgCheckErrorsTruyenqq"
                                                          ItemsSource="{Binding CheckErrors, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Foreground="{StaticResource CyberpunkTextBrush}"
                                                          HeadersVisibility="Column"
                                                          RowHeaderWidth="0"
                                                          GridLinesVisibility="Horizontal"
                                                          HorizontalGridLinesBrush="#1f293d"
                                                          VerticalGridLinesBrush="#1f293d"
                                                          ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                                                          RowStyle="{StaticResource CyberpunkDataGridRow}"
                                                          CellStyle="{StaticResource CyberpunkDataGridCell}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="TIME" Binding="{Binding LastSeen, StringFormat=HH:mm:ss}" Width="85"/>
                                                        <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="90"/>
                                                        <DataGridTextColumn Header="BOOK" Binding="{Binding BookName}" Width="180"/>
                                                        <DataGridTextColumn Header="CHAPTER" Binding="{Binding ChapterName}" Width="110"/>
                                                        <DataGridTextColumn Header="PAGE" Binding="{Binding PageDisplay}" Width="60"/>
                                                        <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorMessage}" Width="*"/>
                                                        <DataGridTextColumn Header="COUNT" Binding="{Binding OccurrenceCount}" Width="60"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Border>
                                            <Grid Visibility="Collapsed">
                                                <RichTextBox Name="txtTruyenqqLog" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0" Foreground="#a8ffb2" FontFamily="Consolas, Courier New" FontSize="11" IsReadOnly="True" Padding="10"/>
                                                <ToggleButton Name="chkAutoScrollTruyenqqLog" Style="{StaticResource ToggleButtonSwitch}" IsChecked="True" Height="16" Width="32"/>
                                                <Button Name="btnClearTruyenqqLog" Content="CLEAR" Click="BtnClearTruyenqqLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <!-- nettruyen tab -->
                        <TabItem Header="nettruyen" Style="{StaticResource CyberpunkTabItem}">
                            <TabItem.Tag>
                                <SolidColorBrush Color="#00ffff"/>
                            </TabItem.Tag>
                            <Grid Margin="0,10,0,0">
                                <Border Name="borderNettruyenLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Section Title -->
                                            <RowDefinition Height="Auto"/> <!-- URL Input -->
                                            <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                            <RowDefinition Height="Auto"/> <!-- Page Info -->
                                            <RowDefinition Height="0"/>    <!-- Row Range Input -->
                                            <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                            <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="📜 HISTORY" Click="BtnOpenHistory_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="25" FontSize="10" Padding="8,0" VerticalAlignment="Center"/>
                                            <Button Grid.Column="3" Content="📌 BOOKMARKS" Click="BtnOpenBookmarks_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="25" FontSize="10" Padding="8,0" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Target URL -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                            <TextBlock Text="DOWNLOAD MULTIPLE WITH TAG OR ARTIST" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <TextBox Name="txtNettruyenTagUrl" 
                                                        Text="https://nettruyenviet10.com/tim-truyen/adventure"
                                                        Background="#0e121a" 
                                                        BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                        Height="32"/>
                                        </StackPanel>

                                        <!-- Fetch Info Action -->
                                        <Grid Grid.Row="2" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnNettruyenFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnNettruyenFetchInfo_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="45" FontSize="12"/>
                                            <Button Grid.Column="2" Name="btnNettruyenFetchCaptcha" Content="DELETE COOKIE" Click="BtnCaptcha_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35"/>
                                        </Grid>

                                        <!-- Page Info Status -->
                                        <Grid Grid.Row="3" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="TOTAL PAGES" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtNettruyenTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="32" HorizontalContentAlignment="Center" TextChanged="TxtNettruyenTotalPages_TextChanged"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtNettruyenPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtNettruyenPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Page Range Input (Unused, height set to 0) -->
                                        <Grid Grid.Row="4" Height="0" Margin="0"/>

                                        <!-- Scrape & Direct Import Actions -->
                                        <Grid Grid.Row="5" Margin="0,15,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnNettruyenScrape" Content="GET LINK" Click="BtnNettruyenScrape_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="48" FontSize="12"/>
                                            <Button Grid.Column="2" Name="btnNettruyenCrawlMore" Content="GET MORE" Click="BtnNettruyenCrawlMore_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="48" FontSize="12"/>
                                            <Button Grid.Column="4" Name="btnNettruyenPasteDirect" Content="PASTE DIRECT LINK" Click="BtnNettruyenPasteDirect_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="48" FontSize="12"/>
                                        </Grid>

                                        <!-- Check Error Panel -->
                                        <Grid Grid.Row="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
