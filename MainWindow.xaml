                                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Foreground="{StaticResource CyberpunkTextBrush}"
                                                          HeadersVisibility="Column"
                                                          RowHeaderWidth="0"
                                                          GridLinesVisibility="Horizontal"
                                                          HorizontalGridLinesBrush="#1f293d"
                                                          VerticalGridLinesBrush="#1f293d"
                                                          ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                                                          RowStyle="{StaticResource CyberpunkDataGridRow}"
                                                          CellStyle="{StaticResource CyberpunkDataGridCell}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="TIME" Binding="{Binding LastSeen, StringFormat=HH:mm:ss}" Width="85" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                        <DataGridTextColumn Header="BOOK" Binding="{Binding DisplayBook}" Width="260" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                        <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorMessage}" Width="300" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Border>
                                            <Grid Visibility="Collapsed">
                                                <RichTextBox Name="txtNhentaiLog" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0" Foreground="#a8ffb2" FontFamily="Consolas, Courier New" FontSize="11" IsReadOnly="True" Padding="10"/>
                                                <ToggleButton Name="chkAutoScrollNhentaiLog" Style="{StaticResource ToggleButtonSwitch}" IsChecked="True" Height="16" Width="32"/>
                                                <Button Name="btnClearNhentaiLog" Content="CLEAR" Click="BtnClearNhentaiLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- hentaiera tab -->
                        <TabItem Header="hentaiera" Style="{StaticResource CyberpunkTabItem}">
                            <TabItem.Tag>
                                <SolidColorBrush Color="#00a8ff"/>
                            </TabItem.Tag>
                            <Grid Margin="0,10,0,0">
                                <Border Name="borderHentaieraLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Section Title -->
                                            <RowDefinition Height="Auto"/> <!-- URL Input -->
                                            <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                            <RowDefinition Height="Auto"/> <!-- Page Info -->
                                            <RowDefinition Height="0"/>    <!-- Row Range Input -->
                                            <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                            <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                        </Grid.RowDefinitions>

                                        <!-- Panel Header with Bookmarks & History -->
                                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                            <TextBlock Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <WrapPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button Name="btnOpenHomepageHentaiera" Tag="hentaiera" Content="🏠 HOMEPAGE" Click="BtnOpenHomepage_Click" Style="{StaticResource CompactCyanButton}" MinWidth="86" Padding="8,0" FontWeight="Bold"/>
                                                <Button Content="📜 HISTORY" Click="BtnOpenHistory_Click" Style="{StaticResource CompactCyanButton}" MinWidth="78" Padding="8,0" FontWeight="Bold"/>
                                                <Button Content="📌 BOOKMARKS" Click="BtnOpenBookmarks_Click" Style="{StaticResource CompactCyanButton}" MinWidth="94" Padding="8,0" FontWeight="Bold"/>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- Target URL -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                            <TextBlock Text="TARGET TAG URL" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <TextBox Name="txtHentaieraTagUrl" 
                                                        Text="https://hentaiera.com/artist/yamamoto/popular/"
                                                        Background="#0e121a" 
                                                        BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                        Height="32"/>
                                        </StackPanel>

                                        <!-- Fetch Info Action -->
                                        <Grid Grid.Row="2" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnHentaieraFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnHentaieraFetchInfo_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="45" FontSize="12"/>
                                            <Button Grid.Column="2" Name="btnHentaieraFetchCaptcha" Content="DELETE COOKIE" Click="BtnCaptcha_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35"/>
                                        </Grid>

                                        <!-- Page Info Status -->
                                        <Grid Grid.Row="3" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="TOTAL PAGES" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtHentaieraTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" CaretBrush="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="32" HorizontalContentAlignment="Center" TextChanged="TxtHentaieraTotalPages_TextChanged"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtHentaieraPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtHentaieraPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="4" Height="0" Margin="0"/>

                                        <!-- Scrape & Direct Import Actions -->
                                        <Grid Grid.Row="5" Margin="0,15,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnHentaieraScrape" Content="GET LINK" Click="BtnHentaieraScrape_Click" Style="{StaticResource WideActionButton}"/>
                                            <Button Grid.Column="2" Name="btnHentaieraCrawlMore" Content="GET MORE" Click="BtnHentaieraCrawlMore_Click" Style="{StaticResource WideActionButton}"/>
                                            <Button Grid.Column="4" Name="btnHentaieraPasteDirect" Content="PASTE DIRECT LINK" Click="BtnHentaieraPasteDirect_Click" Style="{StaticResource WideActionButton}"/>
                                        </Grid>

                                        <!-- Check Error Panel -->
                                        <Grid Grid.Row="6" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="CHECK ERROR" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CheckErrors.Count, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=TOTAL: {0}}" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Button Grid.Column="2" Name="btnClearCheckErrorsHentaiera" Content="CLEAR" Click="BtnClearCheckErrors_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                            <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                                <DataGrid Name="dgCheckErrorsHentaiera"
                                                          ItemsSource="{Binding CheckErrors, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Foreground="{StaticResource CyberpunkTextBrush}"
                                                          HeadersVisibility="Column"
                                                          RowHeaderWidth="0"
                                                          GridLinesVisibility="Horizontal"
                                                          HorizontalGridLinesBrush="#1f293d"
                                                          VerticalGridLinesBrush="#1f293d"
                                                          ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                                                          RowStyle="{StaticResource CyberpunkDataGridRow}"
                                                          CellStyle="{StaticResource CyberpunkDataGridCell}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="TIME" Binding="{Binding LastSeen, StringFormat=HH:mm:ss}" Width="85" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                        <DataGridTextColumn Header="BOOK" Binding="{Binding DisplayBook}" Width="260" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                        <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorMessage}" Width="300" ElementStyle="{StaticResource CheckErrorWrapTextStyle}"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Border>
                                            <Grid Visibility="Collapsed">
                                                <RichTextBox Name="txtHentaieraLog" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0" Foreground="#a8ffb2" FontFamily="Consolas, Courier New" FontSize="11" IsReadOnly="True" Padding="10"/>
                                                <ToggleButton Name="chkAutoScrollHentaieraLog" Style="{StaticResource ToggleButtonSwitch}" IsChecked="True" Height="16" Width="32"/>
                                                <Button Name="btnClearHentaieraLog" Content="CLEAR" Click="BtnClearHentaieraLog_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>

                <Border Grid.Row="1" Margin="0,8,0,0" Style="{StaticResource WorkspaceSectionCard}">
                    <StackPanel>
                        <TextBlock Text="QUICK ACTIONS FOR CURRENT LIST"
                                   Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Sau khi lấy danh sách, bạn có thể copy nhanh hoặc dọn hàng chờ ở đây."
                                   Style="{StaticResource PanelSectionHint}"/>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Name="btnCopyLinksOnly" Content="COPY LINKS" Click="BtnCopyLinksOnly_Click" Style="{StaticResource CompactCyanButton}" MinWidth="112" Width="Auto" Padding="12,3" FontWeight="Bold"/>
                            <Button Name="btnCopyNamesAndLinks" Content="COPY NAME+LINK" Click="BtnCopyNamesAndLinks_Click" Style="{StaticResource CompactPinkButton}" MinWidth="148" Width="Auto" Padding="12,3" FontWeight="Bold"/>
                            <Button Name="btnClearResults" Content="CLEAR" Click="BtnClear_Click" Style="{StaticResource CompactCyanButton}" MinWidth="92" Width="Auto" Padding="12,3" FontWeight="Bold"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right Output Panel (Shared) -->
            <Border Name="borderRightPanel" Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource CyberpunkCard}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Filter & Sort Toolbar -->
                        <RowDefinition Height="Auto"/> <!-- Top Status -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                        <RowDefinition Height="Auto"/> <!-- Download Section -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Name="txtResultsHeader" Text="EXTRACTED GALLERY LINKS" Style="{StaticResource PanelSectionTitle}" VerticalAlignment="Center" Margin="0,0,12,4"/>
                            <TextBlock Text="Review queue, tick what you want, then start download."
                                       Style="{StaticResource PanelSectionHint}"
                                       Margin="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Name="txtWordWrapLabel" Text="WORD WRAP" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ToggleButton Name="chkWordWrap" Style="{StaticResource ToggleButtonSwitch}" Height="20" Width="40"/>
                            </StackPanel>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Name="txtTotalBooksLabel" Text="Total Books: " Foreground="{StaticResource CyberpunkTextBrush}" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Name="lblLinkCount" Text="0" Foreground="{StaticResource CyberpunkYellowBrush}" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Toolbar for Filtering and Sorting -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,10" Orientation="Horizontal">
                        <Button Name="btnSortByLatestChapter" Content="sort by latest chapter" Click="BtnSortByLatestChapter_Click" Style="{StaticResource CompactCyanButton}" MinWidth="152" Width="Auto" Padding="10,2"/>
                        <Button Name="btnRestoreOrder" Content="RESTORE ORDER" Click="BtnRestoreOrder_Click" Style="{StaticResource CompactCyanButton}" MinWidth="112" Width="Auto" Padding="10,2"/>
                        <Button Name="btnDuplicateName" Content="DUPLICATE NAME" Click="BtnDuplicateName_Click" Style="{StaticResource CompactPinkButton}" MinWidth="118" Width="Auto" Padding="10,2"/>
                        <Button Name="btnNoLinkViHentai" Content="NO LINK (VI-HENTAI)" Click="BtnNoLinkViHentai_Click" Style="{StaticResource CompactPinkButton}" MinWidth="138" Width="Auto" Padding="10,2"/>
                        <Button Name="btnReverseOrder" Content="REVERSE ORDER" Click="BtnReverseOrder_Click" Style="{StaticResource CompactCyanButton}" MinWidth="126" Width="Auto" Padding="10,2"/>
                        <Button Name="btnClearComplete" Content="CLEAR COMPLETE BOOKS" Click="BtnClearComplete_Click" Style="{StaticResource CompactPinkButton}" MinWidth="162" Width="Auto" Padding="10,2"/>
                    </WrapPanel>

                    <Border Grid.Row="2" Style="{StaticResource WorkspaceSectionCard}" Padding="12" Margin="0,0,0,10">
                        <TextBlock Text="{Binding Text, ElementName=lblStatus}"
                                   Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Scraped links DataGrid -->
                    <DataGrid Grid.Row="3" 
                              Name="dgResults"
                              Style="{StaticResource CyberpunkDataGrid}"
                              ColumnHeaderStyle="{StaticResource CyberpunkDataGridColumnHeader}"
                              RowStyle="{StaticResource CyberpunkDataGridRow}"
                              CellStyle="{StaticResource CyberpunkDataGridCell}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              PreviewKeyDown="DgResults_PreviewKeyDown"
                              PreviewTextInput="DgResults_PreviewTextInput"
                              PreviewMouseLeftButtonDown="DgResults_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.ScrollUnit="Item"
                              EnableRowVirtualization="True"
                              Margin="0,0,0,10">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Tích chọn dòng đang bôi đen (Check Selected)" Click="MenuCheckSelected_Click"/>
                                    <MenuItem Header="Bỏ tích dòng đang bôi đen (Uncheck Selected)" Click="MenuUncheckSelected_Click"/>
                                    <MenuItem Header="Đảo tick các dòng đang bôi đen (Check inverted rows)" Click="MenuInvertSelectedRows_Click"/>
                                    <MenuItem Header="Đảo ngược trạng thái tích (Invert Checked)" Click="MenuInvertChecked_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📌 Bookmark dòng đang chọn" Click="MenuBookmarkSelected_Click"/>
                                    <MenuItem Header="🌐 Mở link trong trình duyệt" Click="MenuOpenInBrowser_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy link các dòng đang chọn (Copy Selected Links)" Click="MenuCopySelectedLinks_Click"/>
                                <Separator/>
                                <MenuItem Header="Xóa các dòng đang bôi đen (Delete Selected)" Click="MenuDeleteSelected_Click"/>
                                <MenuItem Header="Xóa các dòng đã tích (Delete Checked)" Click="MenuDeleteChecked_Click"/>
                                <Separator/>
                                <MenuItem Header="Tải các dòng đang bôi đen (Download highlighted lines)" Click="MenuDownloadSelected_Click"/>
                                <MenuItem Header="Tải các dòng đã tích (Download selected lines)" Click="MenuDownloadChecked_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <!-- Checkbox Column -->
                            <DataGridTemplateColumn Width="38">
                                <DataGridTemplateColumn.Header>
                                    <Grid HorizontalAlignment="Center">
                                        <CheckBox Name="chkSelectAll" Click="ChkSelectAll_Click"/>
                                    </Grid>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Gallery Details Column (Vertical stack of Name and Link) -->
                            <DataGridTemplateColumn x:Name="colGalleryDetails" Width="*">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="CHI TIẾT TRUYỆN (TITLE &amp; URL)" Foreground="{StaticResource CyberpunkPinkBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Button Name="btnSortByName" Content="⇅" Click="BtnSortByName_Click" Width="22" Height="18" Padding="0" FontSize="10" ToolTip="SORT BY NAME">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="MinWidth" Value="0"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="3,1" Orientation="Vertical">
                                            <!-- Title -->
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="Bold" 
                                                       FontSize="11"
                                                       Margin="0,0,0,1">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource CyberpunkYellowBrush}"/>
                                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=chkWordWrap}" Value="True">
                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasNoChapters}" Value="True">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Link -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Link}" 
                                                           Foreground="{StaticResource CyberpunkCyanBrush}" 
                                                           FontSize="10"
                                                           Margin="0,0,8,0"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChecked, ElementName=chkWordWrap}" Value="True">
                                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Chapter Count -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding LinkCount, StringFormat=mới nhất: {0}}" 
                                                           Foreground="{StaticResource CyberpunkMutedTextBrush}" 
                                                           FontSize="9"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                             <!-- Status Column -->
                             <DataGridTemplateColumn x:Name="colStatus" Width="170">
                                 <DataGridTemplateColumn.Header>
                                     <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                         <TextBlock Text="TRẠNG THÁI (STATUS)" Foreground="{StaticResource CyberpunkPinkBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                         <Button Name="btnSortByStatus" Content="⇅" Click="BtnSortByStatus_Click" Width="22" Height="18" Padding="0" FontSize="10" ToolTip="SORT BY STATUS">
                                             <Button.Style>
                                                 <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                     <Setter Property="Margin" Value="0"/>
                                                     <Setter Property="MinWidth" Value="0"/>
                                                 </Style>
                                             </Button.Style>
                                         </Button>
                                     </StackPanel>
                                 </DataGridTemplateColumn.Header>
                                 <DataGridTemplateColumn.CellTemplate>
                                     <DataTemplate>
                                         <Grid Margin="3,1">
                                             <Grid.Style>
                                                 <Style TargetType="Grid">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding ShouldShowStatus}" Value="False">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </Grid.Style>
                                             <Grid.RowDefinitions>
                                                 <RowDefinition Height="Auto"/>
                                                 <RowDefinition Height="Auto"/>
                                             </Grid.RowDefinitions>

                                             <!-- Row 0: Status Text, Action Buttons and Error Button -->
                                             <Grid Grid.Row="0" Margin="0,0,0,4">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                 </Grid.ColumnDefinitions>

                                                 <!-- Status Display -->
                                                 <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Background="Transparent">
                                                     <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource CyberpunkCyanBrush}" Text="{Binding DisplayStatusText}">
                                                         <TextBlock.Style>
                                                             <Style TargetType="TextBlock">
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                         <Setter Property="Foreground" Value="Red"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </TextBlock.Style>
                                                     </TextBlock>
                                                 </StackPanel>

                                                 <!-- Row Buttons -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                                                    <!-- Stop Button -->
                                                    <Button Content="⏹️" Click="BtnRowStop_Click" Width="22" Height="18" Margin="1,0" Padding="0" FontSize="8" ToolTip="Stop download">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonPink}">
                                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                     <DataTrigger Binding="{Binding Status}" Value="Queued">
                                                                         <Setter Property="Visibility" Value="Visible"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                 </StackPanel>

                                                 <!-- Error Button -->
                                                 <Button Grid.Column="2" Content="{Binding ErrorCount, StringFormat=Err: {0}}" 
                                                         Click="BtnShowErrors_Click"
                                                         VerticalAlignment="Center"
                                                         Margin="4,0,0,0" Height="18" Padding="3,0" FontSize="9">
                                                     <Button.Style>
                                                         <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                             <Setter Property="Visibility" Value="Visible"/>
                                                             <Setter Property="Background" Value="#ff2222"/>
                                                             <Setter Property="BorderBrush" Value="#ff4444"/>
                                                             <Setter Property="Foreground" Value="White"/>
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding ErrorCount}" Value="0">
                                                                     <Setter Property="Visibility" Value="Collapsed"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Button.Style>
                                                 </Button>
                                             </Grid>

                                             <!-- Row 1: Progress Bar with Text Overlay -->
                                                 <Grid Grid.Row="1" Height="12" Margin="0,1,0,0">
                                                 <Grid.Style>
                                                     <Style TargetType="Grid">
                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                             <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Grid.Style>

                                                 <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100" Foreground="{StaticResource CyberpunkCyanBrush}" Style="{StaticResource ProgressBarSuccess}" Height="12" VerticalAlignment="Center"/>
                                                 
                                                 <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}" 
                                                            Foreground="Red" 
                                                            FontSize="8" 
                                                            FontWeight="Bold"
                                                            HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                             </Grid>
                                         </Grid>
                                     </DataTemplate>
                                 </DataGridTemplateColumn.CellTemplate>
                             </DataGridTemplateColumn>

                             <!-- Process Column -->
                            <DataGridTemplateColumn x:Name="colProcess" Width="160">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="TIẾN TRÌNH (PROCESS)" Foreground="{StaticResource CyberpunkPinkBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Button Name="btnSortByProcess" Content="⇅" Click="BtnSortByProcess_Click" Width="22" Height="18" Padding="0" FontSize="10" ToolTip="SORT BY PROCESS">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="MinWidth" Value="0"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                  <DataGridTemplateColumn.CellTemplate>
                                      <DataTemplate>
                                          <StackPanel Margin="3,1" Orientation="Vertical" Background="Transparent">
                                             <StackPanel.Style>
                                                 <Style TargetType="StackPanel">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding ShouldShowProcess}" Value="False">
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </StackPanel.Style>

                                             <!-- Row 1: Downloading Chapter -->
                                             <TextBlock Text="{Binding DisplayDownloadingChapter}" 
                                                        Foreground="{StaticResource CyberpunkYellowBrush}" 
                                                        FontSize="10" 
                                                        FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis"/>

                                             <!-- Row 2: Page Progress -->
                                             <TextBlock Text="{Binding DisplayDownloadingPageProgress}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        FontSize="9" 
                                                        Margin="0,1,0,0"/>
                                         </StackPanel>
                                     </DataTemplate>
                                 </DataGridTemplateColumn.CellTemplate>
                             </DataGridTemplateColumn>

                            <!-- Action Buttons Column -->
                            <DataGridTemplateColumn x:Name="colViewLink" Header="VIEW" Width="86">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="🌐" 
                                                    Tag="{Binding Link}" 
                                                    Click="BtnOpenLinkInRow_Click"
                                                    Width="28" Height="24" Margin="1,0"
                                                    Style="{StaticResource CyberpunkButtonCyan}"
                                                    FontSize="12" Padding="0"
                                                    ToolTip="OPEN LINK"/>
                                            <Button Content="📁" 
                                                    DataContext="{Binding}"
                                                    Click="BtnOpenFolderInRow_Click"
                                                    Width="28" Height="24" Margin="1,0"
                                                    Style="{StaticResource CyberpunkButtonPink}"
                                                    FontSize="12" Padding="0"
                                                    ToolTip="OPEN FOLDER"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Download Section -->
                    <Border Grid.Row="4" Style="{StaticResource WorkspaceSectionCard}" Padding="16" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Section title -->
                                    <RowDefinition Height="Auto"/> <!-- Path and Search -->
                                    <RowDefinition Height="5"/>
                                    <RowDefinition Height="Auto"/> <!-- Folder Actions and Chapter Selection -->
                                    <RowDefinition Height="Auto"/> <!-- Archive Progress -->
                                    <RowDefinition Height="Auto"/> <!-- Connections and Start Download -->
                                </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="DOWNLOAD SETTINGS"
                                       Style="{StaticResource PanelSectionTitle}"
                                       Margin="0,0,0,12"/>

                            <!-- Row 0: Path and Search -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "DOWNLOAD PATH" Label -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>    <!-- Textbox for folder path -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- BROWSE button -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/> <!-- OPEN FOLDER button -->
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/> <!-- SEARCH Label -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="260"/>  <!-- Search Textbox -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="DOWNLOAD PATH" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>

                                <TextBox Grid.Column="2" Name="txtDownloadPath" 
                                            Style="{StaticResource SurfaceTextBox}"
                                            IsReadOnly="True"/>

                                <Button Grid.Column="4" Name="btnBrowseFolder" Content="BROWSE" Click="BtnBrowseFolder_Click" Style="{StaticResource CompactCyanButton}" Width="72" Margin="0"/>

                                <Button Grid.Column="6" Name="btnOpenFolder" Content="OPEN FOLDER" Click="BtnOpenFolder_Click" Style="{StaticResource CompactCyanButton}" Width="92" Margin="0"/>

                                <TextBlock Name="txtSearchLabel" Grid.Column="8" Text="SEARCH" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="10" Name="txtFilter" 
                                         TextChanged="TxtFilter_TextChanged"
                                         Style="{StaticResource SurfaceTextBox}"
                                         ToolTip="Tìm kiếm tên truyện..."/>
                            </Grid>

                            <!-- Row 2: Folder Actions and Chapter Selection -->
                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "FOLDER ACTIONS" Label -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- COMPRESS BOOKS button -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/> <!-- EXTRACT BOOKS button -->
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/> <!-- CHAPTER Label -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>    <!-- Chapter Textbox -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="txtFolderActionsLabel" Grid.Column="0" Text="FOLDER ACTIONS" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Name="btnCompressBooks" Content="COMPRESS" Click="BtnCompressBooks_Click" Style="{StaticResource CompactCyanButton}" Width="94" Margin="0"/>
                                <Button Grid.Column="4" Name="btnExtractBooks" Content="EXTRACT" Click="BtnExtractBooks_Click" Style="{StaticResource CompactPinkButton}" Width="86" Margin="0"/>

                                <TextBlock Name="txtChapterSelectionLabel" Grid.Column="6" Text="CHAPTER SELECTION" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="8" Name="txtChapterSelection"
                                         Style="{StaticResource SurfaceTextBox}"
                                         ToolTip="Nhập chap cần tải. VD: 1-10;15;20-25 (để trống = tải tất cả)"/>
                            </Grid>

                            <Grid Grid.Row="4" Name="archiveProgressPanel" Margin="0,8,0,6" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="txtArchiveProgressLabel"
                                           Grid.Column="0"
                                           Text="ARCHIVE PROGRESS"
                                           Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>

                                <ProgressBar Name="archiveProgressBar"
                                             Grid.Column="2"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Height="14"
                                             VerticalAlignment="Center"
                                             Foreground="{StaticResource CyberpunkCyanBrush}"
                                             Style="{StaticResource ProgressBarSuccess}"/>

                                <TextBlock Name="txtArchiveProgressValue"
                                           Grid.Column="4"
                                           Text="0%"
                                           Foreground="{StaticResource CyberpunkYellowBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>

                                <Button Name="btnArchivePause"
                                        Grid.Column="6"
                                        Content="PAUSE"
                                        Click="BtnArchivePause_Click"
                                        Style="{StaticResource CompactCyanButton}"
                                        Width="72"
                                        Margin="0"
                                        IsEnabled="False"/>

                                <Button Name="btnArchiveStop"
                                        Grid.Column="8"
                                        Content="STOP"
                                        Click="BtnArchiveStop_Click"
                                        Style="{StaticResource CompactPinkButton}"
                                        Width="68"
                                        Margin="0"
                                        IsEnabled="False"/>
                            </Grid>

                            <!-- Row 4: Connections and Actions -->
                            <Grid Grid.Row="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- "CONNECTION" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox connections -->
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/> <!-- "MULTI DOWNLOAD" Label -->
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="50"/>  <!-- ComboBox multi download -->
                                    <ColumnDefinition Width="*"/>   <!-- Spacer / Stretch -->
                                    <ColumnDefinition Width="Auto"/> <!-- START DOWNLOAD button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- STOP button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- RETRY ERRORS button -->
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/> <!-- ERROR LOG button -->
                                </Grid.ColumnDefinitions>

                                <TextBlock Name="txtConnectionLabel" Grid.Column="0" Text="CONNECTION" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2" Name="cmbConnections" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="26"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectionChanged="CmbConnections_SelectionChanged"
                                          SelectedIndex="0">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CyberpunkComboBoxItemStyle}"/>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="32"/>
                                </ComboBox>

                                <TextBlock Name="txtDownloadMultipleBookLabel" Grid.Column="4" Text="DOWNLOAD MULTIPLE BOOK" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="6" Name="cmbMultiDownload" 
                                          Style="{StaticResource CyberpunkComboBox}"
                                          Height="26"
                                          VerticalContentAlignment="Center"
                                          HorizontalContentAlignment="Center"
                                          SelectedIndex="1"
                                          SelectionChanged="CmbMultiDownload_SelectionChanged">
                                    <ComboBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Background="#121622"/>
                                        </ItemsPanelTemplate>
                                    </ComboBox.ItemsPanel>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource CyberpunkComboBoxItemStyle}"/>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                </ComboBox>

                                <TextBlock Grid.Column="7" Name="txtBuildInfo"
                                           Foreground="{StaticResource CyberpunkYellowBrush}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,10,0"/>

                                <Button Grid.Column="8" Name="btnStartDownload" Content="START" Click="BtnStartDownload_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="34" MinWidth="92" FontSize="12" ToolTip="DOWNLOAD ALL"/>
                                <Button Grid.Column="12" Name="btnStopDownload" Content="STOP" Click="BtnStopDownload_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="34" MinWidth="82" FontSize="12" IsEnabled="False" ToolTip="Stop"/>
                                <Button Grid.Column="14" Name="btnRetryErrors" Content="RETRY" Click="BtnRetryErrors_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="34" MinWidth="82" FontSize="12" ToolTip="RETRY ALL"/>
                                <Button Grid.Column="16" Name="btnRetryErrorLog" Content="LOG" Click="BtnRetryErrorLog_Click" Style="{StaticResource CyberpunkButtonPink}" Height="34" MinWidth="82" FontSize="12" ToolTip="ERROR LOG"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Name="lblStatus" Text="Ready." Visibility="Collapsed"/>
    </Grid>
    </Border>
    </Grid>
    </Grid>
</Window>
