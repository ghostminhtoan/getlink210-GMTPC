<Window x:Class="get_link_manga.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:get_link_manga"
        mc:Ignorable="d"
        Title="Comic-GMTPC v1.0" Height="900" Width="800" MinWidth="1080" MinHeight="560"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SizeChanged="Window_SizeChanged"
        StateChanged="MainWindow_StateChanged"
        AllowDrop="True"
        PreviewDragOver="MainWindow_PreviewDragOver"
        Drop="MainWindow_Drop"
        PreviewKeyDown="MainWindow_PreviewPanelHotkeys"
        Loaded="MainWindow_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MainWindowStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    
    <Grid Name="rootLayout" Margin="18" PreviewMouseLeftButtonDown="RootLayout_PreviewMouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Ellipse Width="420"
                     Height="420"
                     Fill="#163A61"
                     Opacity="0.14"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-120,-140,0,0"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="110"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="520"
                     Height="520"
                     Fill="#6A2B2A"
                     Opacity="0.10"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,-180,-190"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="130"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,0,0,0"
                Panel.ZIndex="500"
                Background="#E0090D16"
                CornerRadius="12"
                BorderBrush="{StaticResource CyberpunkBorderBrush}"
                BorderThickness="1"
                Padding="5"
                SnapsToDevicePixels="True">
            <StackPanel Orientation="Horizontal">
                <Button Name="btnMainMove"
                        Content="MOVE"
                        PreviewMouseLeftButtonDown="BtnMainMove_PreviewMouseLeftButtonDown"
                        Style="{StaticResource CyberpunkButtonCyan}"
                        Width="66"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        FontSize="11"
                        FontWeight="Bold"
                        Cursor="SizeAll"
                        ToolTip="Move window"/>
                <Button Name="btnPinWindow"
                        Content="PIN"
                        Click="BtnMainTheme_Click"
                        Style="{StaticResource CyberpunkButtonCyan}"
                        Width="44"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        FontSize="11"
                        FontWeight="Bold"
                        ToolTip="Pin window"/>
                <Button Name="btnMainMinimize"
                        Content="-"
                        Click="BtnMainMinimize_Click"
                        Style="{StaticResource CyberpunkButtonCyan}"
                        Width="32"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        FontSize="14"
                        FontWeight="Bold"
                        ToolTip="Minimize"/>
                <Button Name="btnMainMaximize"
                        Content="&#xE922;"
                        FontFamily="Segoe MDL2 Assets"
                        Click="BtnMainMaximize_Click"
                        Style="{StaticResource CyberpunkButtonCyan}"
                        Width="32"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        FontSize="10"
                        FontWeight="Bold"
                        ToolTip="Maximize"/>
                <Button Name="btnMainClose"
                        Content="X"
                        Click="BtnMainClose_Click"
                        Style="{StaticResource CyberpunkButtonPink}"
                        Width="32"
                        Height="26"
                        Padding="0"
                        FontSize="12"
                        FontWeight="Bold"
                        ToolTip="Close"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="0" Name="gridMainContent" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="520"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Name="headerPanel" Grid.Column="0" Grid.Row="0" Padding="16" Margin="0,0,0,0" Style="{StaticResource CyberpunkCard}" Background="{StaticResource CyberpunkHeroBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Name="txtHeaderTitle"
                                       Text="Comic GMTPC"
                                       Style="{StaticResource HeroTitleText}"
                                       Margin="0,2,0,0"/>
