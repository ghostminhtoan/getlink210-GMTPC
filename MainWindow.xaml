                                                <Button Content="HISTORY" Click="BtnOpenHistory_Click" Style="{StaticResource CompactCyanButton}" MinWidth="78" Padding="8,0" FontWeight="Bold"/>
                                                <Button Content="BOOKMARKS" Click="BtnOpenBookmarks_Click" Style="{StaticResource CompactCyanButton}" MinWidth="94" Padding="8,0" FontWeight="Bold"/>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- Target URL -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                            <TextBlock Text="TARGET TAG URL" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <TextBox Name="txtHentaieraTagUrl" 
                                                        Text="https://hentaiera.com/artist/yamamoto/popular/"
                                                        Background="#0e121a" 
                                                        BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                        Height="32"/>
                                        </StackPanel>

                                        <!-- Fetch Info Action -->
                                        <Grid Grid.Row="2" Margin="0,0,0,15">
