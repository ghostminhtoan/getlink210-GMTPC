                                                        <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="90"/>
                                                        <DataGridTextColumn Header="BOOK" Binding="{Binding BookName}" Width="180"/>
                                                        <DataGridTextColumn Header="CHAPTER" Binding="{Binding ChapterName}" Width="110"/>
                                                        <DataGridTextColumn Header="PAGE" Binding="{Binding PageDisplay}" Width="60"/>
                                                        <DataGridTextColumn Header="ERROR" Binding="{Binding ErrorMessage}" Width="*"/>
