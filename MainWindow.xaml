                                                    Style="{StaticResource CyberpunkButtonPink}"
                                                    FontSize="12" Padding="0"
                                                    ToolTip="OPEN FOLDER"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
