                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Foreground="{StaticResource CyberpunkTextBrush}"
                                                          HeadersVisibility="Column"
                                                          RowHeaderWidth="0"
                                                          GridLinesVisibility="Horizontal"
                                                          HorizontalGridLinesBrush="#1f293d"
                                                          VerticalGridLinesBrush="#1f293d"
