<Window x:Class="get_link_manga.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:get_link_manga"
        mc:Ignorable="d"
        Title="Comic-GMTPC v1.0" Height="920" Width="1540"
        Background="{StaticResource CyberpunkDarkBrush}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        SizeChanged="Window_SizeChanged"
        Loaded="MainWindow_Loaded">

    <Window.Resources>
        <Style x:Key="ToggleButtonSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#16304b"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BackgroundBorder" 
                                CornerRadius="10" 
                                Background="#16304b" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Ellipse x:Name="Thumb" 
                                         Fill="#a0b4c7" 
                                         Width="12" Height="12" 
                                         HorizontalAlignment="Left" 
                                         Margin="3,0,3,0"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#20486E"/>
                                <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="{StaticResource CyberpunkCyanBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource CyberpunkCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#102133"/>
                                <Setter TargetName="BackgroundBorder" Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#7d92a8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ProgressBarSuccess" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource CyberpunkCyanBrush}"/>
            <Setter Property="Background" Value="#0B1726"/>
        </Style>
        <Style x:Key="TabControlInLine" TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource CyberpunkDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
        </Style>
        <!-- DataGrid Style -->
        <Style x:Key="CyberpunkDataGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="#0d1828"/>
            <Setter Property="RowBackground" Value="#0d1828"/>
            <Setter Property="AlternatingRowBackground" Value="#132235"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#223550"/>
            <Setter Property="VerticalGridLinesBrush" Value="#223550"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <!-- Column Header Style -->
        <Style x:Key="CyberpunkDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#16253A"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1c2f47"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row Style -->
        <Style x:Key="CyberpunkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#17304a"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#20486E"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell Style -->
        <Style x:Key="CyberpunkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactCyanButton" TargetType="Button" BasedOn="{StaticResource CyberpunkButtonCyan}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="CompactPinkButton" TargetType="Button" BasedOn="{StaticResource CyberpunkButtonPink}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="WideActionButton" TargetType="Button" BasedOn="{StaticResource CyberpunkButtonImportant}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="CheckErrorWrapTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="CyberpunkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#0E1A29"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        
        <!-- ComboBoxItem Style for dropdown items -->
        <Style x:Key="CyberpunkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource CyberpunkCardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#17304A"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#20486E"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Custom TabItem Style -->
        <Style x:Key="CyberpunkTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="#0E1A29"/>
            <Setter Property="BorderBrush" Value="#223550"/>
            <Setter Property="Foreground" Value="#C6D5E5"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" 
                                Margin="0,0,6,0" 
                                CornerRadius="10,10,0,0" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                Cursor="Hand">
                            <TextBlock x:Name="headerText" 
                                       Text="{TemplateBinding Header}"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#122238"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="#c8d4e2"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#17304A"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="#ffffff"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#17304A"/>
                                <Setter TargetName="headerText" Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeroStepCard" TargetType="Border">
            <Setter Property="Background" Value="#15293E"/>
            <Setter Property="BorderBrush" Value="#31506E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="PanelSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="PanelSectionHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CyberpunkMutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CyberpunkMutedTextBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SurfaceTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1828"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource CyberpunkTextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource CyberpunkCyanBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="#0D1828"/>
            <Setter Property="BorderBrush" Value="{StaticResource CyberpunkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="WorkspaceSectionCard" TargetType="Border">
            <Setter Property="Background" Value="#0E1A29"/>
            <Setter Property="BorderBrush" Value="#203954"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </Window.Resources>
    
    <Grid Name="rootLayout" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Name="gridMainContent" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="520"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Name="headerPanel" Grid.Column="0" Grid.Row="0" Padding="18" Margin="0,0,0,0" Style="{StaticResource CyberpunkCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0" Visibility="Collapsed">
                        <TextBlock Name="txtHeaderTitle"
                                   Text="Comic GMTPC"
                                   Foreground="{StaticResource CyberpunkTextBrush}"
                                   FontFamily="Bahnschrift SemiBold, Segoe UI Semibold"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Name="txtHeaderSubtitle" Text="Simple flow: choose website, paste link, review list, then download."
                                   Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                   FontSize="13"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Name="headerUtilityPanel" Grid.Row="0" Width="220" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,8">
                        <Border Name="languageCard" Style="{StaticResource MetricCard}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="INTERFACE LANGUAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="10" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,0">
                                    <TextBlock Name="txtLanguageLabel"
                                               Text="ENG"
                                               Foreground="{StaticResource CyberpunkMutedTextBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <ToggleButton Name="tglLanguage"
                                                  Style="{StaticResource ToggleButtonSwitch}"
                                                  Width="46"
                                                  Height="20"
                                                  VerticalAlignment="Center"
                                                  IsChecked="True"
                                                  Checked="TglLanguage_Checked"
                                                  Unchecked="TglLanguage_Unchecked"/>
                                    <TextBlock Name="txtLanguageTarget"
                                               Text="VI"
                                               Foreground="{StaticResource CyberpunkCyanBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <WrapPanel Name="headerStepsPanel" Grid.Row="1" Margin="0,0,0,2">
                        <Border Style="{StaticResource HeroStepCard}">
                            <StackPanel>
                                <TextBlock Text="STEP 1" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="CHOOSE SOURCE" Foreground="{StaticResource CyberpunkTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource HeroStepCard}">
                            <StackPanel>
                                <TextBlock Text="STEP 2" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="PASTE LINK" Foreground="{StaticResource CyberpunkTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource HeroStepCard}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="STEP 3" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="DOWNLOAD" Foreground="{StaticResource CyberpunkTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <WrapPanel Name="headerActionsPanel" Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Name="btnNewList" Content="NEW" Click="BtnNewList_Click" Style="{StaticResource CompactCyanButton}" MinWidth="84" Padding="12,3" FontWeight="Bold"/>
                        <Button Name="btnSaveList" Content="SAVE DEFAULT" Click="BtnSave_Click" Style="{StaticResource CompactCyanButton}" MinWidth="126" Padding="12,3" FontWeight="Bold"/>
                        <Button Name="btnLoadList" Content="LOAD DEFAULT" Click="BtnLoad_Click" Style="{StaticResource CompactCyanButton}" MinWidth="126" Padding="12,3" FontWeight="Bold"/>
                        <Button Name="btnSaveCustomList" Content="SAVE CUSTOM" Click="BtnSaveCustom_Click" Style="{StaticResource CompactPinkButton}" MinWidth="126" Padding="12,3" FontWeight="Bold"/>
                        <Button Name="btnLoadCustomList" Content="LOAD CUSTOM" Click="BtnLoadCustom_Click" Style="{StaticResource CompactPinkButton}" MinWidth="126" Padding="12,3" FontWeight="Bold"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Name="leftPanelHost" Grid.Column="0" Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <!-- Tab Control for Crawlers (Left Side) -->
            <!-- Tab Control for Crawlers (Left Side) -->
            <TabControl Name="tabLeftPanel" Grid.Row="0" Style="{StaticResource TabControlInLine}" Background="Transparent" BorderThickness="0">
                <!-- MANGA Parent Tab -->
                <TabItem x:Name="tabMangaRootItem" Header="MANGA" Style="{StaticResource CyberpunkTabItem}" Tag="{StaticResource CyberpunkCyanBrush}">
                    <TabControl Name="tabManga" Style="{StaticResource TabControlInLine}" Background="Transparent" BorderThickness="0" SelectionChanged="TabManga_SelectionChanged">
                        <!-- truyenqq tab -->
                        <TabItem x:Name="tabTruyenqqItem" Header="truyenqq" Style="{StaticResource CyberpunkTabItem}">
                            <TabItem.Tag>
                                <SolidColorBrush Color="#00ff66"/>
                            </TabItem.Tag>
                            <Grid Margin="0,10,0,0">
                                <Border Name="borderTruyenqqLeftPanel" Style="{StaticResource CyberpunkCard}" Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Section Title -->
                                            <RowDefinition Height="Auto"/> <!-- URL Input -->
                                            <RowDefinition Height="Auto"/> <!-- Fetch Button -->
                                            <RowDefinition Height="Auto"/> <!-- Page Info -->
                                            <RowDefinition Height="0"/>    <!-- Row Range Input -->
                                            <RowDefinition Height="Auto"/> <!-- Scrape Button -->
                                            <RowDefinition Height="*"/>    <!-- Progress Logs -->
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                            <TextBlock Name="txtTruyenqqSectionTitle" Text="PARAMETERS CONFIG" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <WrapPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button Name="btnOpenHomepageTruyenqq" Tag="truyenqq" Content="🏠 HOMEPAGE" Click="BtnOpenHomepage_Click" Style="{StaticResource CompactCyanButton}" MinWidth="86" Padding="8,0" FontWeight="Bold"/>
                                                <Button Name="btnOpenHistory" Content="📜 HISTORY" Click="BtnOpenHistory_Click" Style="{StaticResource CompactCyanButton}" MinWidth="78" Padding="8,0" FontWeight="Bold"/>
                                                <Button Name="btnOpenBookmarks" Content="📌 BOOKMARKS" Click="BtnOpenBookmarks_Click" Style="{StaticResource CompactCyanButton}" MinWidth="94" Padding="8,0" FontWeight="Bold"/>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- Target URL -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                            <TextBlock Name="txtTruyenqqTargetLabel" Text="DOWNLOAD MULTIPLE WITH TAG OR ARTIST" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <TextBox Name="txtTruyenqqTagUrl" 
                                                        Text="https://truyenqqko.com/the-loai/action-26"
                                                        Background="#0e121a" 
                                                        BorderBrush="{StaticResource CyberpunkBorderBrush}" 
                                                        Foreground="{StaticResource CyberpunkTextBrush}" 
                                                        CaretBrush="{StaticResource CyberpunkCyanBrush}"
                                                        Height="32"/>
                                        </StackPanel>

                                        <!-- Fetch Info Action -->
                                        <Grid Grid.Row="2" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnTruyenqqFetchInfo" Content="ANALYZE TARGET PAGE" Click="BtnTruyenqqFetchInfo_Click" Style="{StaticResource CyberpunkButtonImportant}" Height="45" FontSize="12"/>
                                            <Button Grid.Column="2" Name="btnTruyenqqFetchCaptcha" Content="DELETE COOKIE" Click="BtnCaptcha_Click" Style="{StaticResource CyberpunkButtonPink}" Height="35"/>
                                        </Grid>

                                        <!-- Page Info Status (TOTAL, FROM, TO pages all on the same row) -->
                                        <Grid Grid.Row="3" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Name="txtTruyenqqTotalPagesLabel" Text="TOTAL PAGES" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtTruyenqqTotalPages" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkYellowBrush}" FontSize="13" FontWeight="Bold" Height="32" HorizontalContentAlignment="Center" TextChanged="TxtTruyenqqTotalPages_TextChanged"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="FROM PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtTruyenqqPageFrom" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="TO PAGE" Foreground="{StaticResource CyberpunkMutedTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBox Name="txtTruyenqqPageTo" Text="1" Background="#0e121a" BorderBrush="{StaticResource CyberpunkBorderBrush}" Foreground="{StaticResource CyberpunkTextBrush}" CaretBrush="{StaticResource CyberpunkCyanBrush}" Height="32" HorizontalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Page Range Input (Unused, height set to 0) -->
                                        <Grid Grid.Row="4" Height="0" Margin="0"/>

                                        <!-- Scrape & Direct Import Actions -->
                                        <Grid Grid.Row="5" Margin="0,8,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Name="btnTruyenqqScrape" Content="GET LINK" Click="BtnTruyenqqScrape_Click" Style="{StaticResource WideActionButton}"/>
                                            <Button Grid.Column="2" Name="btnTruyenqqCrawlMore" Content="GET MORE" Click="BtnTruyenqqCrawlMore_Click" Style="{StaticResource WideActionButton}"/>
                                            <Button Grid.Column="4" Name="btnTruyenqqPasteDirect" Content="PASTE DIRECT LINK" Click="BtnTruyenqqPasteDirect_Click" Style="{StaticResource WideActionButton}"/>
                                        </Grid>

                                        <!-- Check Error Panel -->
                                        <Grid Grid.Row="6" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="CHECK ERROR" Foreground="{StaticResource CyberpunkPinkBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CheckErrors.Count, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=TOTAL: {0}}" Foreground="{StaticResource CyberpunkCyanBrush}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Button Grid.Column="2" Name="btnClearCheckErrorsTruyenqq" Content="CLEAR" Click="BtnClearCheckErrors_Click" Style="{StaticResource CyberpunkButtonCyan}" Height="20" Width="60" FontSize="9" Padding="0"/>
                                            </Grid>
                                            <Border Grid.Row="1" Background="#06090e" BorderBrush="{StaticResource CyberpunkBorderBrush}" BorderThickness="1" CornerRadius="3">
                                                <DataGrid Name="dgCheckErrorsTruyenqq"
                                                          ItemsSource="{Binding CheckErrors, RelativeSource={RelativeSource AncestorType=Window}}"
