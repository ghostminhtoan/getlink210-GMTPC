  <Target Name="GenerateBuildInfo"
          BeforeTargets="BeforeBuild"
          Condition="'$(Configuration)' == 'Release' and '$(AutoStampBuildInfo)' == 'true'">
    <PropertyGroup>
      <BuildTimestamp>$([System.String]::Format('{0:yyyy-MM-dd ∕ hh.mm.ss tt}', $([System.DateTime]::Now)))</BuildTimestamp>
    </PropertyGroup>
    <ItemGroup>
      <BuildInfoLines Include="namespace get_link_manga" />
      <BuildInfoLines Include="{" />
      <BuildInfoLines Include="    public static class BuildInfo" />
      <BuildInfoLines Include="    {" />
      <BuildInfoLines Include="        public const string DisplayText = &quot;$(BuildTimestamp)&quot;%3B" />
      <BuildInfoLines Include="    }" />
      <BuildInfoLines Include="}" />
    </ItemGroup>
    <WriteLinesToFile File="$(BuildInfoFile)"
                      Lines="@(BuildInfoLines)"
                      Overwrite="true"
                      Encoding="UTF-8" />
    <Message Text="Stamped BuildInfo.cs with $(BuildTimestamp)" Importance="High" />
  </Target>
  <Target Name="IncludeGeneratedWpfCode"
          BeforeTargets="CoreCompile">
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)**\*.g.cs"
               Exclude="@(Compile)" />
    </ItemGroup>
  </Target>
  <Target Name="PublishReleaseArtifact"
          AfterTargets="Build"
          Condition="'$(Configuration)' == 'Release' and '$(AutoPublishRelease)' == 'true'">
    <MakeDir Directories="$(ReleasePackageDir)" />
    <ItemGroup>
      <ReleasePackageFiles Include="$(ReleasePackageDir)\**\*" />
      <ReleasePackageSubdirectories Include="$(ReleasePackageDir)\**\" />
    </ItemGroup>
    <Delete Files="@(ReleasePackageFiles)" />
    <RemoveDir Directories="@(ReleasePackageSubdirectories)" />
    <Copy SourceFiles="$(TargetPath)"
          DestinationFiles="$(ReleasePackageDir)\$(TargetFileName)" />
    <Message Text="Published $(TargetFileName) to $(ReleasePackageDir)" Importance="High" />
  </Target>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
